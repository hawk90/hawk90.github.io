{
  "name": "astro-hawk-blog",
  "type": "module",
  "version": "1.0.0",
  "description": "A premium Astro blog theme with dark mode, search, series, SEO, analytics, comments, and i18n support",
  "keywords": [
    "astro",
    "blog",
    "theme",
    "tailwindcss",
    "dark-mode",
    "seo",
    "search",
    "giscus",
    "analytics",
    "i18n"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hawk90/hawk90.github.io"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "sync:book-notes": "node scripts/sync-book-notes.mjs",
    "diagrams": "bash scripts/build-diagrams.sh",
    "diagrams:force": "bash scripts/build-diagrams.sh --force",
    "diagrams:watch": "bash scripts/watch-diagrams.sh"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.1",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@expressive-code/plugin-line-numbers": "^0.42.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^6.0.5",
    "astro-expressive-code": "^0.42.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "satori": "^0.18.3",
    "satori-html": "^0.3.2",
    "tailwindcss": "^4.1.18"
  }
}
