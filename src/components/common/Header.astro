---
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import Logo from './Logo.astro';
import { NAV_CONFIG, ADMIN_CONFIG } from '../../consts/config';
import { t } from '../../consts/ui-strings';

const currentPath = Astro.url.pathname;
const showAdminLink = ADMIN_CONFIG.enabled;

function isNavActive(href: string, match: ReadonlyArray<string> | undefined): boolean {
  const prefixes = match ?? [href];
  return prefixes.some(
    (p) => currentPath === p || (p !== '/' && currentPath.startsWith(p + '/')),
  );
}
---

<header
  id="site-header"
  class="sticky top-0 z-50 bg-[var(--color-bg-primary)]/88 backdrop-blur-sm border-b border-transparent transition-[border-color,background-color,box-shadow] duration-200 ease-out"
  data-scrolled="false"
>
  <nav class="container flex items-center justify-between h-16">
    <Logo />

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-8">
      <ul class="flex items-center gap-6">
        {NAV_CONFIG.map((link) => (
          <li>
            <a
              href={link.href}
              data-nav-link={link.href}
              data-nav-match={(link.match ?? [link.href]).join(',')}
              class:list={[
                'text-sm font-medium transition-colors',
                isNavActive(link.href, link.match)
                  ? 'text-[var(--color-accent)]'
                  : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="flex items-center gap-1">
        <!-- Search Button — pill icon on small screens, faux search bar on lg+ -->
        <button
          type="button"
          data-search-trigger
          class="search-trigger group inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-lg px-2 py-1.5 lg:pl-2.5 lg:pr-1.5 lg:w-56 transition-colors hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-tertiary)]"
          aria-label={t('search')}
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <span class="hidden lg:inline flex-1 text-left">{t('search_trigger_hint')}</span>
          <kbd class="hidden lg:inline-flex items-center justify-center min-w-[18px] h-5 px-1 text-[11px] bg-[var(--color-bg-tertiary)] rounded border border-[var(--color-border)] font-mono">/</kbd>
        </button>

        <LanguageSwitcher />
        <ThemeToggle />

        <!-- Admin -->
        {showAdminLink && (
          <a href="/admin" class="btn btn-ghost p-2" aria-label="Admin">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </a>
        )}

        <!-- Settings -->
        <a href="/settings" class="btn btn-ghost p-2" aria-label="Settings">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Mobile Menu Button -->
    <div class="flex md:hidden items-center gap-1">
      <LanguageSwitcher />
      <ThemeToggle />

      <!-- Admin -->
      {showAdminLink && (
        <a href="/admin" class="btn btn-ghost p-2" aria-label="Admin">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </a>
      )}

      <!-- Settings -->
      <a href="/settings" class="btn btn-ghost p-2" aria-label="Settings">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </a>
      <button
        type="button"
        data-mobile-menu-trigger
        class="btn btn-ghost p-2"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div
    data-mobile-menu
    class="hidden md:hidden border-t border-[var(--color-border)] bg-[var(--color-bg-primary)]"
  >
    <ul class="container py-4 space-y-2">
      {NAV_CONFIG.map((link) => (
        <li>
          <a
            href={link.href}
            data-nav-link={link.href}
            data-nav-match={(link.match ?? [link.href]).join(',')}
            class:list={[
              'block py-2 text-base font-medium transition-colors',
              isNavActive(link.href, link.match)
                ? 'text-[var(--color-accent)]'
                : 'text-[var(--color-text-secondary)]',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  import { onPageLoad } from '../../lib/lifecycle';

  // Mobile hamburger menu
  onPageLoad(() => {
    const trigger = document.querySelector<HTMLButtonElement>('[data-mobile-menu-trigger]');
    const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
    if (!trigger || !menu) return;

    const close = () => {
      trigger.setAttribute('aria-expanded', 'false');
      menu.classList.add('hidden');
      trigger.focus();
    };
    const onTrigger = () => {
      if (trigger.getAttribute('aria-expanded') === 'true') return close();
      trigger.setAttribute('aria-expanded', 'true');
      menu.classList.remove('hidden');
      (menu.querySelector('a') as HTMLElement | null)?.focus();
    };
    const links = menu.querySelectorAll('a');
    trigger.addEventListener('click', onTrigger);
    links.forEach((l) => l.addEventListener('click', close));
    return () => {
      trigger.removeEventListener('click', onTrigger);
      links.forEach((l) => l.removeEventListener('click', close));
    };
  });

  // Defensive: re-derive active nav highlight from the live pathname.
  // SSR's class may be stale after View Transition / Speculation Rules
  // activation; we toggle the same classes server-side rendered.
  const syncNavActive = () => {
    const path = location.pathname;
    document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]').forEach((a) => {
      const href = a.dataset.navLink || a.getAttribute('href') || '';
      const prefixes = a.dataset.navMatch ? a.dataset.navMatch.split(',') : [href];
      const active = prefixes.some((p) => path === p || (p !== '/' && path.startsWith(p + '/')));
      const isMobile = a.classList.contains('block');
      a.classList.toggle('text-[var(--color-accent)]', active);
      a.classList.toggle('text-[var(--color-text-secondary)]', !active);
      if (!isMobile) a.classList.toggle('hover:text-[var(--color-text-primary)]', !active);
    });
  };
  syncNavActive();
  document.addEventListener('astro:page-load', syncNavActive);
  document.addEventListener('astro:after-swap', syncNavActive);
  window.addEventListener('pageshow', syncNavActive);

  // Subtle bg + border + shadow once the user scrolls past ~16px.
  onPageLoad(() => {
    const header = document.getElementById('site-header');
    if (!header) return;
    const onScroll = () => {
      header.dataset.scrolled = String(window.scrollY > 16);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
    return () => window.removeEventListener('scroll', onScroll);
  });
</script>
