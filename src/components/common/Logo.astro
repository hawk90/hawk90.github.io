---
import { BRAND_CONFIG } from '../../consts/config';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<a
  href="/"
  class:list={[
    'group flex items-baseline font-bold text-xl transition-colors',
    className,
  ]}
>
  <span class="text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors">{BRAND_CONFIG.logoText}</span>
  <span class="text-[var(--color-accent)]">{BRAND_CONFIG.logoSuffix}</span>
</a>
