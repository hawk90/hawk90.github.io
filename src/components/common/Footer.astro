---
import { BRAND_CONFIG, SOCIAL_CONFIG } from '../../consts/config';

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] mt-auto no-print">
  <div class="container py-12">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <!-- Copyright -->
      <div class="text-sm text-[var(--color-text-muted)]">
        <p>&copy; {currentYear} {BRAND_CONFIG.copyright}. All rights reserved.</p>
      </div>

      <!-- Social Links -->
      <div class="flex items-center gap-4">
        {SOCIAL_CONFIG.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors"
            aria-label={link.name}
          >
            <Fragment set:html={link.icon} />
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
