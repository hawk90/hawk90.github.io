---
import { BRAND_CONFIG, SOCIAL_CONFIG, FOOTER_LINKS } from '../../consts/config';

const currentYear = new Date().getFullYear();
const socialLinks = SOCIAL_CONFIG.filter(s => s.name !== 'RSS');
---

<footer class="border-t border-[var(--color-border)] mt-auto no-print bg-[var(--color-bg-primary)]">
  <div class="container py-5">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 text-sm">
      <!-- Brand + copyright -->
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-[var(--color-text-muted)]">
        <a href="/" class="font-bold text-[var(--color-text-primary)] hover:text-[var(--color-accent)] transition-colors">
          {BRAND_CONFIG.logoText}<span class="text-[var(--color-accent)]">{BRAND_CONFIG.logoSuffix}</span>
        </a>
        <span aria-hidden="true">·</span>
        <span class="text-xs">&copy; {currentYear} {BRAND_CONFIG.copyright}</span>
      </div>

      <!-- Footer links + socials -->
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[var(--color-text-muted)] text-xs">
        {FOOTER_LINKS.map((link) => (
          <a href={link.href} class="hover:text-[var(--color-text-primary)] transition-colors">
            {link.label}
          </a>
        ))}
        {socialLinks.length > 0 && (
          <span class="text-[var(--color-border)]" aria-hidden="true">|</span>
        )}
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith('http') || link.href.startsWith('mailto') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="hover:text-[var(--color-text-primary)] transition-colors inline-flex items-center gap-1"
            aria-label={link.name}
          >
            <span class="w-4 h-4 [&>svg]:w-4 [&>svg]:h-4"><Fragment set:html={link.icon} /></span>
            <span>{link.name}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
