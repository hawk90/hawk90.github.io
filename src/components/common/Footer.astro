---
import { BRAND_CONFIG, SOCIAL_CONFIG, NAV_CONFIG } from '../../consts/config';

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] mt-auto no-print bg-[var(--color-bg-primary)]">
  <div class="container py-5">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 text-sm">
      <!-- Brand + copyright -->
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-[var(--color-text-muted)]">
        <a href="/" class="font-bold text-[var(--color-text-primary)] hover:text-[var(--color-accent)] transition-colors">
          {BRAND_CONFIG.logoText}<span class="text-[var(--color-accent)]">{BRAND_CONFIG.logoSuffix}</span>
        </a>
        <span aria-hidden="true">·</span>
        <span class="text-xs">&copy; {currentYear} {BRAND_CONFIG.copyright}</span>
      </div>

      <!-- Links + socials -->
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[var(--color-text-muted)] text-xs">
        {NAV_CONFIG.map((link) => (
          <a href={link.href} class="hover:text-[var(--color-text-primary)] transition-colors">
            {link.label}
          </a>
        ))}
        <a href="/archive" class="hover:text-[var(--color-text-primary)] transition-colors">Archive</a>
        <a href="/now" class="hover:text-[var(--color-text-primary)] transition-colors">Now</a>
        <a href="/uses" class="hover:text-[var(--color-text-primary)] transition-colors">Uses</a>
        <a href="/rss.xml" class="hover:text-[var(--color-text-primary)] transition-colors inline-flex items-center gap-1" aria-label="RSS feed">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/></svg>
          RSS
        </a>
        <span class="text-[var(--color-border)]" aria-hidden="true">|</span>
        {SOCIAL_CONFIG.filter((s) => !s.href.startsWith('/rss')).map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="hover:text-[var(--color-text-primary)] transition-colors"
            aria-label={link.name}
          >
            <Fragment set:html={link.icon} />
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
