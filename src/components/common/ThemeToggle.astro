---
/**
 * ThemeToggle — single button switching between dark and light mode.
 *
 * Both icons (sun + moon) are present in the DOM, with CSS choosing
 * which one is visible based on the html.light class. The class is
 * set pre-paint by the inline theme script in BaseLayout, so the
 * correct icon shows from first paint (no FOUC).
 */
---

<button
  type="button"
  class="btn btn-ghost p-2 theme-toggle-btn"
  aria-label="Toggle theme"
  data-theme-toggle
>
  <svg
    class="w-5 h-5 theme-icon-sun"
    aria-hidden="true"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
    />
  </svg>
  <svg
    class="w-5 h-5 theme-icon-moon"
    aria-hidden="true"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
    />
  </svg>
</button>

<style is:global>
  /* Pre-paint icon visibility — uses html.light class set by the
     inline theme script in BaseLayout. Both icons exist in DOM; CSS
     hides the one that doesn't match the current mode. */
  .theme-toggle-btn .theme-icon-moon { display: none; }
  html.light .theme-toggle-btn .theme-icon-sun  { display: none; }
  html.light .theme-toggle-btn .theme-icon-moon { display: block; }
</style>

<script>
  import { toggleTheme } from '../../lib/theme';

  let cleanup: (() => void) | null = null;

  function initThemeToggle() {
    cleanup?.();

    const toggles = document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]');
    if (toggles.length === 0) return;

    function handleClick() {
      toggleTheme();
    }

    toggles.forEach((t) => t.addEventListener('click', handleClick));

    cleanup = () => {
      toggles.forEach((t) => t.removeEventListener('click', handleClick));
    };
  }

  initThemeToggle();
  document.addEventListener('astro:page-load', initThemeToggle);
</script>
