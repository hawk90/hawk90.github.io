---

---

<button
  type="button"
  id="theme-toggle"
  class="btn btn-ghost p-2"
  aria-label="Toggle theme"
>
  <svg
    class="w-5 h-5"
    data-sun-icon
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
    />
  </svg>
  <svg
    class="w-5 h-5"
    data-moon-icon
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
    />
  </svg>
</button>

<script>
  import { toggleTheme, isLightMode } from '../../lib/theme';

  let cleanup: (() => void) | null = null;

  function initThemeToggle() {
    // 이전 리스너 정리
    cleanup?.();

    const toggle = document.getElementById('theme-toggle');
    const sunIcon = document.querySelector('[data-sun-icon]') as HTMLElement;
    const moonIcon = document.querySelector('[data-moon-icon]') as HTMLElement;

    if (!toggle || !sunIcon || !moonIcon) return;

    function updateIcons() {
      const isLight = isLightMode();
      sunIcon.style.display = isLight ? 'none' : 'block';
      moonIcon.style.display = isLight ? 'block' : 'none';
    }

    function handleClick() {
      toggleTheme();
      updateIcons();
    }

    function handleExternalModeChange() {
      updateIcons();
    }

    toggle.addEventListener('click', handleClick);
    window.addEventListener('theme-mode-changed', handleExternalModeChange);
    updateIcons();

    cleanup = () => {
      toggle.removeEventListener('click', handleClick);
      window.removeEventListener('theme-mode-changed', handleExternalModeChange);
    };
  }

  initThemeToggle();
  document.addEventListener('astro:page-load', initThemeToggle);
</script>
