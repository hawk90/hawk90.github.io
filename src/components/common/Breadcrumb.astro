---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="text-sm text-[var(--color-text-muted)] mb-8" aria-label="Breadcrumb">
  <ol class="flex items-center flex-wrap gap-1">
    {items.map((item, index) => (
      <li class="flex items-center">
        {index > 0 && <span class="mx-2">/</span>}
        {item.href ? (
          <a href={item.href} class="hover:text-[var(--color-accent)] transition-colors">
            {item.label}
          </a>
        ) : (
          <span class="text-[var(--color-text-primary)]">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
