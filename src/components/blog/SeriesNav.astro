---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
  currentSlug: string;
  showAll?: boolean;
}

const { posts, currentSlug, showAll = false } = Astro.props;

const currentIndex = posts.findIndex((p) => p.id === currentSlug);
const prevPost = currentIndex > 0 ? posts[currentIndex - 1] : null;
const nextPost = currentIndex < posts.length - 1 ? posts[currentIndex + 1] : null;
---

{!showAll ? (
  <!-- Compact navigation (single line) -->
  <div class="card">
    <div class="flex items-center justify-between gap-4">
      {prevPost ? (
        <a
          href={`/blog/${prevPost.id}`}
          class="flex items-center gap-2 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors"
          data-prev-post
        >
          <span>←</span>
          <span class="truncate max-w-[200px]">{prevPost.data.title}</span>
        </a>
      ) : <div></div>}

      <div class="text-sm text-[var(--color-text-muted)]">
        {currentIndex + 1} / {posts.length}
      </div>

      {nextPost ? (
        <a
          href={`/blog/${nextPost.id}`}
          class="flex items-center gap-2 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors"
          data-next-post
        >
          <span class="truncate max-w-[200px]">{nextPost.data.title}</span>
          <span>→</span>
        </a>
      ) : <div></div>}
    </div>
  </div>
) : (
  <div class="space-y-6">
    <!-- Big prev / next CTAs -->
    <nav
      class="grid sm:grid-cols-2 gap-3"
      aria-label="Previous and next post"
    >
      {prevPost ? (
        <a
          href={`/blog/${prevPost.id}`}
          data-prev-post
          class="series-nav-card group flex flex-col p-5 bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-xl hover:border-[var(--color-accent)] transition-all"
        >
          <div class="text-[10px] uppercase tracking-wider text-[var(--color-text-muted)] mb-2 flex items-center gap-1.5">
            <svg class="w-3 h-3 transition-transform group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/>
            </svg>
            Previous
          </div>
          <span class="text-sm font-semibold leading-snug line-clamp-2 group-hover:text-[var(--color-accent)] transition-colors">
            {prevPost.data.title}
          </span>
        </a>
      ) : (
        <div class="hidden sm:block" aria-hidden="true"></div>
      )}

      {nextPost ? (
        <a
          href={`/blog/${nextPost.id}`}
          data-next-post
          class="series-nav-card group flex flex-col p-5 bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-xl hover:border-[var(--color-accent)] transition-all sm:items-end sm:text-right"
        >
          <div class="text-[10px] uppercase tracking-wider text-[var(--color-text-muted)] mb-2 flex items-center gap-1.5">
            Next
            <svg class="w-3 h-3 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
            </svg>
          </div>
          <span class="text-sm font-semibold leading-snug line-clamp-2 group-hover:text-[var(--color-accent)] transition-colors">
            {nextPost.data.title}
          </span>
        </a>
      ) : (
        <div class="hidden sm:block" aria-hidden="true"></div>
      )}
    </nav>

    <!-- Full series list -->
    <div class="p-5 bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-xl">
      <h3 class="text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-3">
        {posts[0]?.data.series} · {currentIndex + 1} of {posts.length}
      </h3>
      <ol class="space-y-1">
        {posts.map((post, index) => {
          const isCurrent = post.id === currentSlug;
          return (
            <li>
              <a
                href={`/blog/${post.id}`}
                class:list={[
                  'flex items-start gap-2 py-1.5 px-2 -mx-2 text-sm rounded-md transition-colors',
                  isCurrent
                    ? 'bg-[var(--color-accent)]/10 text-[var(--color-accent)] font-medium'
                    : 'text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-tertiary)] hover:text-[var(--color-text-primary)]',
                ]}
              >
                <span class:list={[
                  'shrink-0 w-5 h-5 flex items-center justify-center rounded text-[10px] font-semibold',
                  isCurrent
                    ? 'bg-[var(--color-accent)] text-white'
                    : 'bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)]',
                ]}>{index + 1}</span>
                <span class="line-clamp-1">{post.data.title}</span>
              </a>
            </li>
          );
        })}
      </ol>
    </div>
  </div>
)}

<style>
  .series-nav-card { transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease; }
  .series-nav-card:hover { transform: translateY(-1px); box-shadow: var(--shadow-md); }
</style>
