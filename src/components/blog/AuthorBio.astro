---
/**
 * AuthorBio — renders an author card at the end of a post.
 *
 * Resolution order:
 *   1. <AuthorBio post={post} /> with post.data.author set → look up
 *      AUTHORS registry by id; fall back to the SITE_CONFIG default
 *   2. No post passed → render the about-page default profile
 */
import { ABOUT_DATA } from '../../consts/about';
import { SOCIAL_CONFIG } from '../../consts/config';
import { findAuthor } from '../../consts/authors';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post?: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const author = findAuthor(post?.data.author);

// Compose effective fields with fallbacks from the about page
const name   = author?.name   ?? ABOUT_DATA.name;
const bio    = author?.bio    ?? ABOUT_DATA.tagline;
const avatar = author?.avatar ?? ABOUT_DATA.photo;
const url    = author?.url    ?? '/about';
const social = author?.social;
---

<aside class="author-bio mt-12 p-6 bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-2xl flex flex-col sm:flex-row gap-5 items-start">
  <img
    src={avatar}
    alt={name}
    class="w-16 h-16 rounded-full object-cover shrink-0"
    width="64"
    height="64"
    loading="lazy"
    decoding="async"
  />
  <div class="flex-1 min-w-0">
    <div class="text-[10px] uppercase tracking-wider text-[var(--color-text-muted)] mb-1">Written by</div>
    <a href={url} class="text-base font-semibold hover:text-[var(--color-accent)] transition-colors">
      {name}
    </a>
    <p class="text-sm text-[var(--color-text-secondary)] mt-1.5 leading-relaxed">
      {bio}
    </p>
    <div class="flex flex-wrap items-center gap-3 mt-3">
      <a
        href={url}
        class="inline-flex items-center gap-1 text-xs font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors"
      >
        More about
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
      {/* Per-author social if defined, else fall back to site social */}
      {social ? (
        <div class="flex items-center gap-3 text-xs">
          {social.github && (
            <a href={`https://github.com/${social.github}`} target="_blank" rel="noopener noreferrer"
               class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors">GitHub</a>
          )}
          {social.twitter && (
            <a href={`https://twitter.com/${social.twitter}`} target="_blank" rel="noopener noreferrer"
               class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors">Twitter</a>
          )}
          {social.linkedin && (
            <a href={social.linkedin} target="_blank" rel="noopener noreferrer"
               class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors">LinkedIn</a>
          )}
          {social.email && (
            <a href={`mailto:${social.email}`}
               class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors">Email</a>
          )}
        </div>
      ) : (
        <div class="flex items-center gap-2">
          {SOCIAL_CONFIG.map((s) => (
            <a
              href={s.href}
              target={s.href.startsWith('http') ? '_blank' : undefined}
              rel={s.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors"
              aria-label={s.name}
            >
              <Fragment set:html={s.icon} />
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</aside>
