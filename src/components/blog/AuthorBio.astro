---
import { ABOUT_DATA } from '../../consts/about';
import { SOCIAL_CONFIG } from '../../consts/config';
---

<aside class="author-bio mt-12 p-6 bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-2xl flex flex-col sm:flex-row gap-5 items-start">
  <img
    src={ABOUT_DATA.photo}
    alt={ABOUT_DATA.name}
    class="w-16 h-16 rounded-full object-cover shrink-0"
    width="64"
    height="64"
    loading="lazy"
    decoding="async"
  />
  <div class="flex-1 min-w-0">
    <div class="text-[10px] uppercase tracking-wider text-[var(--color-text-muted)] mb-1">Written by</div>
    <a href="/about" class="text-base font-semibold hover:text-[var(--color-accent)] transition-colors">
      {ABOUT_DATA.name}
    </a>
    <p class="text-sm text-[var(--color-text-secondary)] mt-1.5 leading-relaxed">
      {ABOUT_DATA.tagline}
    </p>
    <div class="flex flex-wrap items-center gap-3 mt-3">
      <a
        href="/about"
        class="inline-flex items-center gap-1 text-xs font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors"
      >
        More about
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
      <div class="flex items-center gap-2">
        {SOCIAL_CONFIG.map((s) => (
          <a
            href={s.href}
            target={s.href.startsWith('http') ? '_blank' : undefined}
            rel={s.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors"
            aria-label={s.name}
          >
            <Fragment set:html={s.icon} />
          </a>
        ))}
      </div>
    </div>
  </div>
</aside>
