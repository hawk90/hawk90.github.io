---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../../lib/utils';
import { getReadingTime } from '../../lib/posts';
import { t } from '../../consts/ui-strings';

interface Props {
  title: string;
  posts: CollectionEntry<'blog'>[];
  kind?: 'latest' | 'updated';
  href?: string;
  hrefLabel?: string;
  emptyLabel?: string;
}

const {
  title,
  posts,
  kind = 'latest',
  href,
  hrefLabel,
  emptyLabel = 'No posts yet.',
} = Astro.props;
---

<section class="card h-full">
  <div class="flex items-center justify-between gap-4 mb-4">
    <h2 class="text-lg font-semibold">{title}</h2>
    {href && hrefLabel && (
      <a href={href} class="text-sm text-[var(--color-accent)] hover:underline">
        {hrefLabel}
      </a>
    )}
  </div>

  {posts.length > 0 ? (
    <ul class="space-y-3">
      {posts.map((post) => {
        const displayDate =
          kind === 'updated' && post.data.updated
            ? post.data.updated
            : post.data.date;
        const readingTime = getReadingTime(post.body || '');
        return (
          <li>
            <a
              href={`/blog/${post.id}`}
              class="block rounded-lg px-1 py-1.5 transition-colors hover:bg-[var(--color-bg-tertiary)]"
            >
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  {post.data.series && (
                    <div class="text-[11px] font-medium text-[var(--color-accent)] mb-1 truncate">
                      {post.data.series}
                    </div>
                  )}
                  <div class="font-medium leading-snug text-[var(--color-text-primary)] line-clamp-2">
                    {post.data.title}
                  </div>
                </div>
                {kind === 'updated' && (
                  <span class="shrink-0 rounded-full bg-[var(--color-accent)]/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-[var(--color-accent)]">
                    {t('updated')}
                  </span>
                )}
              </div>
              <div class="mt-2 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
                <time datetime={displayDate.toISOString()}>
                  {formatDate(displayDate, 'short')}
                </time>
                <span>·</span>
                <span>{readingTime}{t('reading_time_min')}</span>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  ) : (
    <p class="text-sm text-[var(--color-text-muted)]">{emptyLabel}</p>
  )}
</section>
