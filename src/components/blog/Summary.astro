---
/**
 * Summary/TL;DR component for quick overview.
 *
 * Usage in MDX:
 *   import Summary from '../../components/blog/Summary.astro';
 *
 *   <Summary>
 *     - 핵심 포인트 1
 *     - 핵심 포인트 2
 *     - 핵심 포인트 3
 *   </Summary>
 *
 *   <Summary title="이 장의 핵심">
 *     함수는 짧게, 한 가지만 하도록 작성한다.
 *   </Summary>
 *
 *   <Summary variant="tldr">
 *     8칸 탭, K&R 브레이스, snake_case 명명.
 *   </Summary>
 */

interface Props {
  title?: string;
  variant?: 'default' | 'tldr' | 'key-points';
}

const { title, variant = 'default' } = Astro.props;

const config = {
  default: {
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>`,
    defaultTitle: '요약',
    borderColor: 'border-purple-500',
    bgColor: 'bg-purple-500/10',
    iconColor: 'text-purple-500',
  },
  tldr: {
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
    defaultTitle: 'TL;DR',
    borderColor: 'border-orange-500',
    bgColor: 'bg-orange-500/10',
    iconColor: 'text-orange-500',
  },
  'key-points': {
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>`,
    defaultTitle: '핵심 포인트',
    borderColor: 'border-cyan-500',
    bgColor: 'bg-cyan-500/10',
    iconColor: 'text-cyan-500',
  },
};

const c = config[variant];
const displayTitle = title || c.defaultTitle;
---

<aside class:list={['not-prose my-6 rounded-lg border-l-4 p-4', c.borderColor, c.bgColor]} role="note">
  <div class:list={['flex items-center gap-2 font-semibold mb-2', c.iconColor]}>
    <Fragment set:html={c.icon} />
    <span>{displayTitle}</span>
  </div>
  <div class="text-sm text-[var(--color-text-secondary)] [&>p]:m-0 [&>ul]:m-0 [&>ul]:pl-4 [&>ol]:m-0 [&>ol]:pl-4">
    <slot />
  </div>
</aside>
