---
import { t } from '../../consts/ui-strings';

interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
---

<div class="flex items-center gap-3 mt-4">
  <!-- Twitter/X -->
  <a
    href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-lg hover:border-[var(--color-border-hover)] transition-colors"
    aria-label={t('share_twitter')}
  >
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    <span class="hidden sm:inline">Twitter</span>
  </a>

  <!-- LinkedIn -->
  <a
    href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-lg hover:border-[var(--color-border-hover)] transition-colors"
    aria-label={t('share_linkedin')}
  >
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
    <span class="hidden sm:inline">LinkedIn</span>
  </a>

  <!-- Copy Link -->
  <button
    type="button"
    data-copy-url={url}
    class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-lg hover:border-[var(--color-border-hover)] transition-colors cursor-pointer"
    aria-label={t('share_copy_link')}
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
    <span class="hidden sm:inline" data-copy-label>{t('share_copy_link')}</span>
  </button>
</div>

<script>
  import { t } from '../../consts/ui-strings';

  let cleanup: (() => void) | null = null;

  function initShareButtons() {
    cleanup?.();

    const buttons = document.querySelectorAll<HTMLElement>('[data-copy-url]');
    if (buttons.length === 0) return;

    const handlers: Array<{ btn: Element; handler: () => void }> = [];

    buttons.forEach((btn) => {
      const handler = async () => {
        const url = btn.dataset.copyUrl;
        if (!url) return;
        try {
          await navigator.clipboard.writeText(url);
          const label = btn.querySelector('[data-copy-label]');
          if (label) {
            const original = label.textContent;
            label.textContent = t('share_copied');
            setTimeout(() => { label.textContent = original; }, 2000);
          }
        } catch {
          // Clipboard API not available
        }
      };
      btn.addEventListener('click', handler);
      handlers.push({ btn, handler });
    });

    cleanup = () => {
      handlers.forEach(({ btn, handler }) => {
        btn.removeEventListener('click', handler);
      });
    };
  }

  initShareButtons();
  document.addEventListener('astro:page-load', initShareButtons);
</script>
