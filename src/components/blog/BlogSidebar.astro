---
import TagBadge from './TagBadge.astro';
import { CATEGORIES, getTopLevelCategories, getSubCategories } from '../../consts/categories';
import { BLOG_CONFIG } from '../../consts/config';
import { getPublishedPosts, getTagsWithCount } from '../../lib/posts';
import { toSlug, getTagUrl } from '../../lib/utils';
import { onPageLoad } from '../../lib/lifecycle';

interface Props {
  activeFilter?: {
    type: 'tag' | 'series' | 'category';
    value: string;
  };
}

const { activeFilter } = Astro.props;

const allPosts = await getPublishedPosts();
const sortedTags = getTagsWithCount(allPosts);
const { maxTagsInSidebar } = BLOG_CONFIG;

const topCats = getTopLevelCategories();

function isActiveTag(tag: string): boolean {
  return activeFilter?.type === 'tag' && activeFilter.value.toLowerCase() === tag.toLowerCase();
}

function isActiveSeries(series: string): boolean {
  return activeFilter?.type === 'series' && activeFilter.value === series;
}

function isActiveCategory(categoryId: string): boolean {
  return activeFilter?.type === 'category' && activeFilter.value === categoryId;
}

function postsDirectlyIn(catId: string) {
  const subCatIds = CATEGORIES.filter((c) => c.parent === catId).map((c) => c.id);
  return allPosts.filter((p) => {
    if (!p.id.startsWith(catId + '/')) return false;
    return !subCatIds.some((sub) => p.id.startsWith(sub + '/'));
  });
}

function seriesIn(posts: typeof allPosts): string[] {
  return [...new Set(posts.filter((p) => p.data.series).map((p) => p.data.series!))];
}
---

<aside class="hidden lg:block w-72 shrink-0">
  <div class="sticky top-24 max-h-[calc(100vh-7rem)] overflow-y-auto pr-1 space-y-6">
    <!-- All Posts Link -->
    <div>
      <a
        href="/blog"
        class:list={[
          'inline-flex items-center gap-2 text-sm font-medium transition-colors',
          !activeFilter
            ? 'text-[var(--color-accent)]'
            : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]',
        ]}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0l-4-4m4 4l-4 4" />
        </svg>
        All Posts
      </a>
    </div>

    <!-- Category Tree -->
    <div>
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-semibold text-[var(--color-text-muted)] uppercase tracking-wider">Browse</h3>
        <div class="flex gap-1">
          <button
            type="button"
            data-tree-expand-all
            class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent)] px-1.5 py-0.5 rounded transition-colors"
            title="Expand all"
          >Expand</button>
          <button
            type="button"
            data-tree-collapse-all
            class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent)] px-1.5 py-0.5 rounded transition-colors"
            title="Collapse all"
          >Collapse</button>
        </div>
      </div>
      <nav class="space-y-1">
        {topCats.map((cat) => {
          const subCats = getSubCategories(cat.id);
          const directPosts = postsDirectlyIn(cat.id);
          const directSeries = seriesIn(directPosts);
          const totalCount = allPosts.filter((p) => p.id.startsWith(cat.id + '/')).length;
          const isCatActive = isActiveCategory(cat.id);
          const initiallyOpen = isCatActive || subCats.some((s) => isActiveCategory(s.id));
          return (
            <details class="cat-tree" open={initiallyOpen}>
              <summary
                class:list={[
                  'cat-row flex items-center gap-1 rounded-lg transition-colors',
                  isCatActive
                    ? 'bg-[var(--color-accent)]/10 text-[var(--color-accent)]'
                    : 'hover:bg-[var(--color-bg-secondary)]',
                ]}
              >
                <button
                  type="button"
                  class="cat-toggle flex items-center gap-1 py-2 pl-2 pr-1 rounded-l-lg cursor-pointer"
                  aria-expanded={initiallyOpen ? 'true' : 'false'}
                >
                  <svg class="chevron w-3 h-3 shrink-0 text-[var(--color-text-muted)] transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                  </svg>
                </button>
                <a
                  href={`/blog/${cat.id}`}
                  class="flex items-center justify-between flex-1 min-w-0 py-2 pr-2"
                >
                  <span class="flex items-center gap-2 truncate">
                    <span>{cat.icon}</span>
                    <span class="truncate">{cat.name}</span>
                  </span>
                  {totalCount > 0 && <span class="text-xs text-[var(--color-text-muted)] ml-2 shrink-0">{totalCount}</span>}
                </a>
              </summary>

              <!-- Sub-categories -->
              {subCats.length > 0 && (
                <ul class="ml-3 mt-1 space-y-1 border-l border-[var(--color-border)] pl-2">
                  {subCats.map((sub) => {
                    const subPosts = postsDirectlyIn(sub.id);
                    const subSeries = seriesIn(subPosts);
                    const subTotal = allPosts.filter((p) => p.id.startsWith(sub.id + '/')).length;
                    const isSubActive = isActiveCategory(sub.id);
                    return (
                      <li>
                        <details class="cat-tree" open={isSubActive}>
                          <summary
                            class:list={[
                              'cat-row flex items-center gap-1 rounded text-sm transition-colors',
                              isSubActive
                                ? 'bg-[var(--color-accent)]/10 text-[var(--color-accent)] font-medium'
                                : 'text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-secondary)] hover:text-[var(--color-accent)]',
                            ]}
                          >
                            <button
                              type="button"
                              class="cat-toggle flex items-center gap-1 py-1.5 pl-2 pr-1 rounded-l cursor-pointer"
                              aria-expanded={isSubActive ? 'true' : 'false'}
                            >
                              <svg class="chevron w-3 h-3 shrink-0 text-[var(--color-text-muted)] transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                              </svg>
                            </button>
                            <a
                              href={`/blog/${sub.id}`}
                              class="flex items-center justify-between flex-1 min-w-0 py-1.5 pr-2"
                            >
                              <span class="flex items-center gap-1.5 truncate">
                                <span class="text-xs">{sub.icon}</span>
                                <span class="truncate">{sub.name}</span>
                              </span>
                              {subTotal > 0 && <span class="text-xs text-[var(--color-text-muted)] ml-2 shrink-0">{subTotal}</span>}
                            </a>
                          </summary>
                          {subSeries.length > 0 && (
                            <ul class="ml-3 mt-1 space-y-0.5 border-l border-[var(--color-border)] pl-2">
                              {subSeries.map((series) => {
                                const sCount = subPosts.filter((p) => p.data.series === series).length;
                                const sSlug = toSlug(series);
                                const isSeriesActive = isActiveSeries(series);
                                return (
                                  <li>
                                    <a
                                      href={`/series/${sSlug}`}
                                      class:list={[
                                        'flex items-center justify-between w-full py-1 px-2 rounded text-xs transition-colors',
                                        isSeriesActive
                                          ? 'bg-[var(--color-accent)]/10 text-[var(--color-accent)] font-medium'
                                          : 'text-[var(--color-text-muted)] hover:bg-[var(--color-bg-secondary)] hover:text-[var(--color-accent)]',
                                      ]}
                                    >
                                      <span class="truncate">{series}</span>
                                      <span class="text-xs opacity-60">{sCount}</span>
                                    </a>
                                  </li>
                                );
                              })}
                            </ul>
                          )}
                        </details>
                      </li>
                    );
                  })}
                </ul>
              )}

              <!-- Direct series under the top-level (no sub-cat) -->
              {directSeries.length > 0 && (
                <ul class="ml-3 mt-1 space-y-1 border-l border-[var(--color-border)] pl-2">
                  {directSeries.map((series) => {
                    const sCount = directPosts.filter((p) => p.data.series === series).length;
                    const sSlug = toSlug(series);
                    const isSeriesActive = isActiveSeries(series);
                    return (
                      <li>
                        <a
                          href={`/series/${sSlug}`}
                          class:list={[
                            'flex items-center justify-between w-full py-1.5 px-2 rounded text-sm transition-colors',
                            isSeriesActive
                              ? 'bg-[var(--color-accent)]/10 text-[var(--color-accent)] font-medium'
                              : 'text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-secondary)] hover:text-[var(--color-accent)]',
                          ]}
                        >
                          <span class="truncate">{series}</span>
                          <span class="text-xs text-[var(--color-text-muted)]">{sCount}</span>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              )}
            </details>
          );
        })}
      </nav>
    </div>

    <!-- Tags -->
    <div>
      <h3 class="text-sm font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-3">Tags</h3>
      <div class="flex flex-wrap gap-2">
        {sortedTags.slice(0, maxTagsInSidebar).map(([tag]) => {
          const isTagActive = isActiveTag(tag);
          return (
            <a
              href={getTagUrl(tag)}
              class:list={[
                isTagActive && 'ring-2 ring-[var(--color-accent)] ring-offset-2 ring-offset-[var(--color-bg-primary)] rounded-full',
              ]}
            >
              <TagBadge tag={tag} />
            </a>
          );
        })}
      </div>
    </div>
  </div>
</aside>

<style>
  .cat-tree > :not(:first-child) {
    margin-top: 0.25rem;
  }

  /* Hide native disclosure marker — chevron button replaces it */
  .cat-row { list-style: none; cursor: default; }
  .cat-row::-webkit-details-marker { display: none; }
  .cat-row::marker { display: none; }

  .cat-tree[open] .cat-toggle > .chevron {
    transform: rotate(90deg);
  }
</style>

<script>
  onPageLoad(() => {
    const applyAll = (open: boolean) => {
      document.querySelectorAll<HTMLDetailsElement>('.cat-tree').forEach((details) => {
        details.open = open;
        const toggle = details.querySelector<HTMLButtonElement>('.cat-toggle');
        toggle?.setAttribute('aria-expanded', String(open));
      });
    };

    const cleanups: Array<() => void> = [];

    document.querySelectorAll<HTMLButtonElement>('.cat-toggle').forEach((button) => {
      const onClick = (e: MouseEvent) => {
        e.preventDefault();
        e.stopPropagation();
        const details = button.closest<HTMLDetailsElement>('.cat-tree');
        if (!details) return;
        details.open = !details.open;
        button.setAttribute('aria-expanded', String(details.open));
      };
      button.addEventListener('click', onClick);
      cleanups.push(() => button.removeEventListener('click', onClick));
    });

    // Prevent navigation links inside <summary> from also toggling the details
    document.querySelectorAll<HTMLAnchorElement>('.cat-row a').forEach((link) => {
      const onClick = (e: MouseEvent) => {
        e.stopPropagation();
      };
      link.addEventListener('click', onClick);
      cleanups.push(() => link.removeEventListener('click', onClick));
    });

    document.querySelectorAll<HTMLElement>('[data-tree-expand-all]').forEach((button) => {
      const onClick = () => applyAll(true);
      button.addEventListener('click', onClick);
      cleanups.push(() => button.removeEventListener('click', onClick));
    });

    document.querySelectorAll<HTMLElement>('[data-tree-collapse-all]').forEach((button) => {
      const onClick = () => applyAll(false);
      button.addEventListener('click', onClick);
      cleanups.push(() => button.removeEventListener('click', onClick));
    });

    return () => cleanups.forEach((cleanup) => cleanup());
  });
</script>
