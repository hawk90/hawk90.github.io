---
import CategoryTreeNode, { type CategoryTreeNodeData } from './CategoryTreeNode.astro';
import TagBadge from './TagBadge.astro';
import { CATEGORIES, getTopLevelCategories, getSubCategories } from '../../consts/categories';
import { BLOG_CONFIG } from '../../consts/config';
import { getTagsWithCount, type BlogPost } from '../../lib/posts';
import { toSlug, getTagUrl } from '../../lib/utils';
import { onPageLoad } from '../../lib/lifecycle';

interface Props {
  posts: BlogPost[];
  activeFilter?: {
    type: 'tag' | 'series' | 'category';
    value: string;
  };
}

const { activeFilter, posts: allPosts } = Astro.props;
const sortedTags = getTagsWithCount(allPosts);
const { maxTagsInSidebar } = BLOG_CONFIG;

const topCats = getTopLevelCategories();
const categoryById = new Map(CATEGORIES.map((category) => [category.id, category]));
const childrenByParent = new Map(CATEGORIES.map((category) => [category.id, getSubCategories(category.id)]));
const subCategoryIdsByParent = new Map(
  [...childrenByParent.entries()].map(([id, children]) => [id, children.map((sub) => sub.id)]),
);
const postsByCategoryPrefix = new Map(CATEGORIES.map((category) => [category.id, [] as BlogPost[]]));
for (const post of allPosts) {
  const segments = post.id.split('/');
  let current = '';
  for (let i = 0; i < segments.length - 1; i++) {
    current = i === 0 ? segments[i] : `${current}/${segments[i]}`;
    const bucket = postsByCategoryPrefix.get(current);
    if (bucket) bucket.push(post);
  }
}

interface SeriesLink {
  name: string;
  slug: string;
  count: number;
  isActive: boolean;
}

function isActiveTag(tag: string): boolean {
  return activeFilter?.type === 'tag' && activeFilter.value.toLowerCase() === tag.toLowerCase();
}

function isActiveSeries(series: string): boolean {
  return activeFilter?.type === 'series' && activeFilter.value === series;
}

function isActiveCategory(categoryId: string): boolean {
  return activeFilter?.type === 'category' && activeFilter.value === categoryId;
}

function postsDirectlyIn(catId: string) {
  const subCatIds = subCategoryIdsByParent.get(catId) ?? [];
  const prefixedPosts = postsByCategoryPrefix.get(catId) ?? [];
  return prefixedPosts.filter((p) => {
    return !subCatIds.some((sub) => p.id.startsWith(sub + '/'));
  });
}

function buildSeriesLinks(posts: typeof allPosts): SeriesLink[] {
  const counts = new Map<string, number>();
  posts.forEach((post) => {
    if (!post.data.series) return;
    counts.set(post.data.series, (counts.get(post.data.series) ?? 0) + 1);
  });
  return [...counts.entries()].map(([series, count]) => ({
    name: series,
    slug: toSlug(series),
    count,
    isActive: isActiveSeries(series),
  }));
}

function buildCategoryNode(categoryId: string): CategoryTreeNodeData {
  const category = categoryById.get(categoryId);
  if (!category) {
    throw new Error(`Unknown category: ${categoryId}`);
  }

  const children = (childrenByParent.get(category.id) ?? []).map((child) => buildCategoryNode(child.id));
  const directPosts = postsDirectlyIn(category.id);
  const hasActiveDescendant = children.some((child) => child.isActive || child.initiallyOpen);

  return {
    id: category.id,
    name: category.name,
    icon: category.icon,
    count: (postsByCategoryPrefix.get(category.id) ?? []).length,
    isActive: isActiveCategory(category.id),
    initiallyOpen: isActiveCategory(category.id) || hasActiveDescendant,
    children,
    series: buildSeriesLinks(directPosts),
  };
}

const categoryTree = topCats.map((category) => buildCategoryNode(category.id));
---

<aside class="hidden lg:block w-72 shrink-0">
  <div class="sticky top-24 max-h-[calc(100vh-7rem)] overflow-y-auto pr-1">
    <div class="space-y-5">
      <a
        href="/blog"
        data-astro-prefetch="viewport"
        class:list={[
          'inline-flex items-center gap-2 text-sm font-medium transition-colors',
          !activeFilter
            ? 'text-[var(--color-accent)]'
            : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]',
        ]}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0l-4-4m4 4l-4 4" />
        </svg>
        All Posts
      </a>

      <div class="sidebar-divider">
        <div class="flex items-center justify-between mb-3">
          <h3 class="sidebar-section-title">Browse</h3>
          <div class="flex gap-1">
            <button
              type="button"
              data-tree-expand-all
              class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent)] px-1 py-1 transition-colors"
              title="Expand all"
            >Expand</button>
            <button
              type="button"
              data-tree-collapse-all
              class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent)] px-1 py-1 transition-colors"
              title="Collapse all"
            >Collapse</button>
          </div>
        </div>
        <nav class="space-y-1">
          {categoryTree.map((node) => (
            <CategoryTreeNode node={node} />
          ))}
        </nav>
      </div>

      <div class="sidebar-divider">
        <h3 class="sidebar-section-title mb-3">Tags</h3>
        <div class="flex flex-wrap gap-2">
          {sortedTags.slice(0, maxTagsInSidebar).map(([tag]) => {
            const isTagActive = isActiveTag(tag);
            return (
              <a
                href={getTagUrl(tag)}
                data-astro-prefetch="viewport"
                class:list={[
                  isTagActive && 'ring-2 ring-[var(--color-accent)] ring-offset-2 ring-offset-[var(--color-bg-primary)] rounded-full',
                ]}
              >
                <TagBadge tag={tag} />
              </a>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</aside>

<style>
  .cat-tree > :not(:first-child) {
    margin-top: 0.25rem;
  }

  /* Hide native disclosure marker — chevron button replaces it */
  .cat-row { list-style: none; cursor: default; }
  .cat-row::-webkit-details-marker { display: none; }
  .cat-row::marker { display: none; }

  .cat-tree[open] .cat-toggle > .chevron {
    transform: rotate(90deg);
  }
</style>

<script>
  onPageLoad(() => {
    const applyAll = (open: boolean) => {
      document.querySelectorAll<HTMLDetailsElement>('.cat-tree').forEach((details) => {
        details.open = open;
        const toggle = details.querySelector<HTMLButtonElement>('.cat-toggle');
        toggle?.setAttribute('aria-expanded', String(open));
      });
    };

    const cleanups: Array<() => void> = [];

    document.querySelectorAll<HTMLButtonElement>('.cat-toggle').forEach((button) => {
      const onClick = (e: MouseEvent) => {
        e.preventDefault();
        e.stopPropagation();
        const details = button.closest<HTMLDetailsElement>('.cat-tree');
        if (!details) return;
        details.open = !details.open;
        button.setAttribute('aria-expanded', String(details.open));
      };
      button.addEventListener('click', onClick);
      cleanups.push(() => button.removeEventListener('click', onClick));
    });

    // Prevent navigation links inside <summary> from also toggling the details
    document.querySelectorAll<HTMLAnchorElement>('.cat-row a').forEach((link) => {
      const onClick = (e: MouseEvent) => {
        e.stopPropagation();
      };
      link.addEventListener('click', onClick);
      cleanups.push(() => link.removeEventListener('click', onClick));
    });

    document.querySelectorAll<HTMLElement>('[data-tree-expand-all]').forEach((button) => {
      const onClick = () => applyAll(true);
      button.addEventListener('click', onClick);
      cleanups.push(() => button.removeEventListener('click', onClick));
    });

    document.querySelectorAll<HTMLElement>('[data-tree-collapse-all]').forEach((button) => {
      const onClick = () => applyAll(false);
      button.addEventListener('click', onClick);
      cleanups.push(() => button.removeEventListener('click', onClick));
    });

    return () => cleanups.forEach((cleanup) => cleanup());
  });
</script>
