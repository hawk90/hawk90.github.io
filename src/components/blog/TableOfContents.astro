---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="toc text-sm" aria-label="Table of contents">
    <h2 class="sidebar-section-title mb-3">On this page</h2>
    <ul class="toc-list" id="toc-list" role="list">
      {filteredHeadings.map((heading) => (
        <li class:list={['toc-item', `toc-depth-${heading.depth}`]}>
          <a
            href={`#${heading.slug}`}
            class="toc-link block py-1.5 text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors"
            data-heading={heading.slug}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  /* Continuous left rail using ::before; active marker is the link itself */
  .toc-list {
    position: relative;
    padding-left: 0.9rem;
    border-left: 1px solid color-mix(in oklab, var(--color-border) 72%, transparent);
  }
  .toc-item {
    position: relative;
    margin: 0;
  }
  .toc-depth-3 { padding-left: 0.875rem; }
  .toc-link {
    position: relative;
    line-height: 1.4;
    border-radius: 0.75rem;
    padding-left: 0.2rem;
    padding-right: 0.2rem;
  }
  /* Active heading: small accent bar that overlays the rail */
  .toc-link.is-active {
    color: var(--color-accent);
    font-weight: 500;
    background: var(--color-accent-faint);
  }
  .toc-link.is-active::before {
    content: '';
    position: absolute;
    left: calc(-0.75rem - 1px);
    top: 0.25rem;
    bottom: 0.25rem;
    width: 2px;
    background: var(--color-accent);
    border-radius: 1px;
    box-shadow: 0 0 0 3px var(--color-accent-faint);
  }
  /* depth-3 items: indent rail offset for nested */
  .toc-depth-3 .toc-link.is-active::before {
    left: calc(-1.625rem - 1px);
  }
</style>

<script>
  import { onPageLoad } from '../../lib/lifecycle';

  onPageLoad(() => {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (tocLinks.length === 0) return;

    const headingElements: HTMLElement[] = [];
    tocLinks.forEach((link) => {
      const id = link.dataset.heading;
      if (id) {
        const h = document.getElementById(id);
        if (h) headingElements.push(h);
      }
    });

    const update = () => {
      const OFFSET = 120;
      const bodyHeight = document.body.offsetHeight;
      let currentId = '';
      if (window.scrollY + window.innerHeight >= bodyHeight - 20) {
        currentId = headingElements[headingElements.length - 1]?.id || '';
      } else {
        for (const heading of headingElements) {
          if (heading.getBoundingClientRect().top <= OFFSET) currentId = heading.id;
          else break;
        }
      }
      tocLinks.forEach((link) => {
        const isActive = link.dataset.heading === currentId;
        link.classList.toggle('is-active', isActive);
      });
    };

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => { update(); ticking = false; });
    };

    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    return () => window.removeEventListener('scroll', onScroll);
  });
</script>
