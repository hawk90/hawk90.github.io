---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="toc text-sm" aria-label="Table of contents">
    <h2 class="text-xs uppercase tracking-wider text-[var(--color-text-muted)] font-semibold mb-3">
      On this page
    </h2>
    <ul class="toc-list" id="toc-list" role="list">
      {filteredHeadings.map((heading) => (
        <li class:list={['toc-item', `toc-depth-${heading.depth}`]}>
          <a
            href={`#${heading.slug}`}
            class="toc-link block py-1 text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors"
            data-heading={heading.slug}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  /* Continuous left rail using ::before; active marker is the link itself */
  .toc-list {
    position: relative;
    padding-left: 0.75rem;
    border-left: 1px solid var(--color-border);
  }
  .toc-item {
    position: relative;
    margin: 0;
  }
  .toc-depth-3 { padding-left: 0.875rem; }
  .toc-link {
    position: relative;
    line-height: 1.4;
  }
  /* Active heading: small accent bar that overlays the rail */
  .toc-link.is-active {
    color: var(--color-accent);
    font-weight: 500;
  }
  .toc-link.is-active::before {
    content: '';
    position: absolute;
    left: calc(-0.75rem - 1px);
    top: 0.25rem;
    bottom: 0.25rem;
    width: 2px;
    background: var(--color-accent);
    border-radius: 1px;
    box-shadow: 0 0 0 3px var(--color-accent-faint);
  }
  /* depth-3 items: indent rail offset for nested */
  .toc-depth-3 .toc-link.is-active::before {
    left: calc(-1.625rem - 1px);
  }
</style>

<script>
  let cleanup: (() => void) | null = null;

  function initTableOfContents() {
    cleanup?.();

    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (tocLinks.length === 0) return;

    const headingElements: HTMLElement[] = [];

    tocLinks.forEach((link) => {
      const id = link.dataset.heading;
      if (id) {
        const heading = document.getElementById(id);
        if (heading) headingElements.push(heading);
      }
    });

    function updateTocHighlight() {
      const OFFSET = 120;
      const scrollY = window.scrollY;
      const windowHeight = window.innerHeight;
      const bodyHeight = document.body.offsetHeight;
      
      let currentId = '';

      // If we're at the very bottom, highlight the last heading
      if (scrollY + windowHeight >= bodyHeight - 20) {
        currentId = headingElements[headingElements.length - 1]?.id || '';
      } else {
        for (const heading of headingElements) {
          const top = heading.getBoundingClientRect().top;
          if (top <= OFFSET) {
            currentId = heading.id;
          } else {
            break;
          }
        }
      }

      tocLinks.forEach((link) => {
        link.classList.toggle('is-active', link.dataset.heading === currentId);
      });
    }

    let ticking = false;
    function handleScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateTocHighlight();
          ticking = false;
        });
        ticking = true;
      }
    }

    window.addEventListener('scroll', handleScroll, { passive: true });
    updateTocHighlight();

    cleanup = () => {
      window.removeEventListener('scroll', handleScroll);
    };
  }

  initTableOfContents();
  document.addEventListener('astro:page-load', initTableOfContents);
</script>
