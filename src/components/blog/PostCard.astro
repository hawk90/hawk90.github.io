---
import type { CollectionEntry } from 'astro:content';
import { getPostMeta } from '../../lib/posts';
import { BLOG_CONFIG } from '../../consts/config';
import { t } from '../../consts/ui-strings';

interface Props {
  post: CollectionEntry<'blog'>;
  showImage?: boolean;
}

const { post, showImage = true } = Astro.props;
const { formattedDate, formattedUpdatedDate, readingTime, wasUpdated, thumbnail } = getPostMeta(post);
---

<article class="card card-feed group overflow-hidden">
  <a href={`/blog/${post.id}`} class="block">
    {showImage && (
      <div class="relative aspect-[16/9] -mx-5 -mt-5 mb-5 overflow-hidden bg-[var(--color-bg-tertiary)]">
        <img
          src={thumbnail}
          alt={post.data.title}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          width="640"
          height="360"
          loading="lazy"
          decoding="async"
        />
        {post.data.series && (
          <div class="absolute top-3 left-3 text-[11px] font-medium px-2.5 py-1 rounded-full bg-[color:color-mix(in_oklab,var(--color-bg-primary)_32%,transparent)] text-white backdrop-blur-sm">
            {post.data.series}
          </div>
        )}
      </div>
    )}
    {!showImage && post.data.series && (
      <div class="text-xs text-[var(--color-accent)] font-medium mb-2">
        {post.data.series}
      </div>
    )}
    <h3
      class="text-lg font-semibold mb-2 group-hover:text-[var(--color-accent)] transition-colors line-clamp-2"
      transition:name={`title-${post.id}`}
    >
      {post.data.title}
    </h3>
    {wasUpdated && (
      <div class="mb-2">
        <span class="inline-flex items-center rounded-full bg-[var(--color-accent)]/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-[var(--color-accent)]">
          {t('updated')}
        </span>
      </div>
    )}
    {post.data.description && (
      <p class="text-sm text-[var(--color-text-secondary)] mb-4 line-clamp-2">
        {post.data.description}
      </p>
    )}
    <div class="flex flex-col gap-3">
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-[var(--color-text-muted)]">
        <time datetime={post.data.date.toISOString()}>
          {formattedDate}
        </time>
        {wasUpdated && formattedUpdatedDate && (
          <>
            <span>·</span>
            <span>{t('updated')} {formattedUpdatedDate}</span>
          </>
        )}
        <span>·</span>
        <span>{readingTime}{t('reading_time_min')}</span>
      </div>
      <div class="flex flex-wrap gap-1.5">
        {post.data.tags.slice(0, BLOG_CONFIG.maxTagsInCard).map((tag) => (
          <span class="text-xs px-2 py-0.5 bg-[var(--color-bg-tertiary)] rounded-full text-[var(--color-text-muted)]">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </a>
</article>
