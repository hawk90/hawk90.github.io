---
import { COMMENTS_CONFIG } from '../../consts/config';
import { t } from '../../consts/ui-strings';

const config = {
  enabled: String(COMMENTS_CONFIG.enabled),
  repo: COMMENTS_CONFIG.repo,
  repoId: COMMENTS_CONFIG.repoId,
  category: COMMENTS_CONFIG.category,
  categoryId: COMMENTS_CONFIG.categoryId,
  mapping: 'pathname',
  strict: '0',
  reactionsEnabled: '1',
  emitMetadata: '0',
  inputPosition: 'top',
  lang: COMMENTS_CONFIG.lang,
};

const setupMessage = t('giscus_setup_required');
const setupLink = t('giscus_setup_link');
---

{COMMENTS_CONFIG.enabled && (
  <div
    class="giscus-wrapper"
    data-giscus-enabled={config.enabled}
    data-giscus-repo={config.repo}
    data-giscus-repo-id={config.repoId}
    data-giscus-category={config.category}
    data-giscus-category-id={config.categoryId}
    data-giscus-mapping={config.mapping}
    data-giscus-strict={config.strict}
    data-giscus-reactions-enabled={config.reactionsEnabled}
    data-giscus-emit-metadata={config.emitMetadata}
    data-giscus-input-position={config.inputPosition}
    data-giscus-lang={config.lang}
  >
    <div class="giscus"></div>
    <div class="giscus-error hidden p-4 text-center text-sm text-[var(--color-text-muted)] border border-[var(--color-border)] rounded-lg">
      <p>{setupMessage}</p>
      <a href="https://giscus.app" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] hover:underline">
        {setupLink}
      </a>
    </div>
  </div>
)}

<script>
  let observer: MutationObserver | null = null;

  function loadGiscus() {
    const wrapper = document.querySelector('.giscus-wrapper') as HTMLElement | null;
    const errorEl = wrapper?.querySelector('.giscus-error');
    if (!wrapper) return;

    const repoId = wrapper.dataset.giscusRepoId;
    const categoryId = wrapper.dataset.giscusCategoryId;

    if (!repoId || !categoryId) {
      errorEl?.classList.remove('hidden');
      console.warn('Giscus: repoId or categoryId is not configured');
      return;
    }

    if (wrapper.querySelector('script[src*="giscus"]')) return;

    errorEl?.classList.add('hidden');

    const theme = document.documentElement.classList.contains('light')
      ? 'light'
      : 'dark_dimmed';

    const script = document.createElement('script');
    script.src = 'https://giscus.app/client.js';
    script.setAttribute('data-repo', wrapper.dataset.giscusRepo || '');
    script.setAttribute('data-repo-id', repoId);
    script.setAttribute('data-category', wrapper.dataset.giscusCategory || '');
    script.setAttribute('data-category-id', categoryId);
    script.setAttribute('data-mapping', wrapper.dataset.giscusMapping || 'pathname');
    script.setAttribute('data-strict', wrapper.dataset.giscusStrict || '0');
    script.setAttribute('data-reactions-enabled', wrapper.dataset.giscusReactionsEnabled || '1');
    script.setAttribute('data-emit-metadata', wrapper.dataset.giscusEmitMetadata || '0');
    script.setAttribute('data-input-position', wrapper.dataset.giscusInputPosition || 'top');
    script.setAttribute('data-theme', theme);
    script.setAttribute('data-lang', wrapper.dataset.giscusLang || 'ko');
    script.crossOrigin = 'anonymous';
    script.async = true;

    wrapper.appendChild(script);
  }

  function initGiscus() {
    if (observer) {
      observer.disconnect();
      observer = null;
    }

    const wrapper = document.querySelector('.giscus-wrapper') as HTMLElement | null;
    if (!wrapper || wrapper.dataset.giscusEnabled !== 'true') return;

    loadGiscus();

    observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.attributeName === 'class') {
          const iframe = document.querySelector('.giscus-frame') as HTMLIFrameElement | null;
          if (iframe) {
            const theme = document.documentElement.classList.contains('light')
              ? 'light'
              : 'dark_dimmed';
            iframe.contentWindow?.postMessage(
              { giscus: { setConfig: { theme } } },
              'https://giscus.app'
            );
          }
        }
      });
    });

    observer.observe(document.documentElement, { attributes: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGiscus);
  } else {
    initGiscus();
  }

  document.addEventListener('astro:page-load', initGiscus);
</script>
