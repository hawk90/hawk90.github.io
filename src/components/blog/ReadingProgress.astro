---
---

<div
  class="reading-progress fixed top-0 left-0 right-0 h-0.5 z-50 pointer-events-none"
  role="progressbar"
  aria-label="Reading progress"
  aria-valuemin="0"
  aria-valuemax="100"
  aria-valuenow="0"
>
  <div
    class="reading-progress-bar h-full bg-[var(--color-accent)] origin-left transition-[width] duration-100 ease-out"
    style="width: 0%"
  ></div>
</div>

<script>
  import { onPageLoad } from '../../lib/lifecycle';

  onPageLoad(() => {
    const root = document.querySelector<HTMLDivElement>('.reading-progress');
    const bar = root?.querySelector<HTMLDivElement>('.reading-progress-bar');
    if (!root || !bar) return;

    const article = document.querySelector<HTMLElement>('article, [data-reading-target]');
    if (!article) {
      root.style.display = 'none';
      return;
    }

    let rafId = 0;

    const update = () => {
      const rect = article.getBoundingClientRect();
      const total = article.offsetHeight - window.innerHeight;
      if (total <= 0) {
        bar.style.width = '100%';
        root.setAttribute('aria-valuenow', '100');
        return;
      }
      const scrolled = Math.max(0, -rect.top);
      const pct = Math.min(100, Math.max(0, (scrolled / total) * 100));
      bar.style.width = `${pct}%`;
      root.setAttribute('aria-valuenow', String(Math.round(pct)));
    };

    const onScroll = () => {
      if (rafId) return;
      rafId = requestAnimationFrame(() => {
        rafId = 0;
        update();
      });
    };

    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });

    return () => {
      window.removeEventListener('scroll', onScroll);
      window.removeEventListener('resize', onScroll);
      if (rafId) cancelAnimationFrame(rafId);
    };
  });
</script>
