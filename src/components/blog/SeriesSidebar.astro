---
import type { CollectionEntry } from 'astro:content';

interface Props {
  seriesName: string;
  posts: CollectionEntry<'blog'>[];
  currentSlug: string;
}

const { seriesName, posts, currentSlug } = Astro.props;
const currentIndex = posts.findIndex((p) => p.id === currentSlug);

type SeriesPost = CollectionEntry<'blog'>;
const chapterMap = new Map<string, { posts: SeriesPost[]; baseIndex: number }>();
posts.forEach((post, idx) => {
  const parts = post.id.split('/');
  const chapter = parts.length >= 4 ? parts[2] : '_flat';
  let entry = chapterMap.get(chapter);
  if (!entry) {
    entry = { posts: [], baseIndex: idx };
    chapterMap.set(chapter, entry);
  }
  entry.posts.push(post);
});
const chapters = [...chapterMap.entries()].map(([key, value]) => ({
  key,
  posts: value.posts,
  baseIndex: value.baseIndex,
  label: formatChapter(key),
}));
const hasChapters = chapters.some((c) => c.label !== '');

function formatChapter(key: string): string {
  if (key === '_flat') return '';
  const m = key.match(/^ch(\d+)(?:-(.+))?$/);
  if (!m) return key;
  const num = String(parseInt(m[1], 10)).padStart(2, '0');
  if (!m[2]) return `Chapter ${num}`;
  const title = m[2]
    .split('-')
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
  return `Chapter ${num} · ${title}`;
}
---

<nav class="mb-8">
  <button
    type="button"
    class="w-full flex items-center justify-between text-left group"
    data-series-toggle
    aria-expanded="true"
    aria-label={`시리즈 목록 열기/닫기: ${seriesName}`}
  >
    <h3 class="text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-wider">
      {seriesName}
    </h3>
    <div class="flex items-center gap-2">
      <span class="text-xs text-[var(--color-text-muted)]">{currentIndex + 1}/{posts.length}</span>
      <svg
        class="w-4 h-4 text-[var(--color-text-muted)] transition-transform duration-200 rotate-180"
        data-chevron
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </button>

  <div class="mt-3 space-y-4" data-series-list>
    {chapters.map((chapter) => (
      <div>
        {hasChapters && chapter.label && (
          <div class="text-[10px] font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-1 px-2 -mx-2">
            {chapter.label}
          </div>
        )}
        <ol class="space-y-1">
          {chapter.posts.map((post, i) => {
            const badge = hasChapters ? i + 1 : chapter.baseIndex + i + 1;
            const isCurrent = post.id === currentSlug;
            return (
              <li>
                <a
                  href={`/blog/${post.id}`}
                  data-series-current={isCurrent ? '' : undefined}
                  class:list={[
                    'flex items-start gap-2 py-1.5 text-sm transition-colors rounded-md px-2 -mx-2',
                    isCurrent
                      ? 'bg-[var(--color-accent)]/10 text-[var(--color-accent)] font-medium'
                      : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-tertiary)]',
                  ]}
                >
                  <span class:list={[
                    'shrink-0 w-5 h-5 flex items-center justify-center rounded text-xs',
                    isCurrent
                      ? 'bg-[var(--color-accent)] text-white'
                      : 'bg-[var(--color-bg-tertiary)]'
                  ]}>
                    {badge}
                  </span>
                  <span class="line-clamp-2 leading-tight">{post.data.title}</span>
                </a>
              </li>
            );
          })}
        </ol>
      </div>
    ))}
  </div>
</nav>

<script>
  import { onPageLoad } from '../../lib/lifecycle';

  onPageLoad(() => {
    // Auto-scroll the active series item into view within the sidebar's
    // own scroll region. Without this, on long series (40+ items) the
    // user lands on the page but the current entry sits off-screen.
    const current = document.querySelector<HTMLAnchorElement>('[data-series-current]');
    const scrollHost = current?.closest<HTMLElement>('.sidebar-scroll');
    if (current && scrollHost) {
      const hostRect = scrollHost.getBoundingClientRect();
      const itemRect = current.getBoundingClientRect();
      const offset = itemRect.top - hostRect.top - hostRect.height / 3;
      if (Math.abs(offset) > hostRect.height / 3) {
        scrollHost.scrollTo({ top: scrollHost.scrollTop + offset, behavior: 'auto' });
      }
    }

    const toggles = document.querySelectorAll('[data-series-toggle]');
    if (toggles.length === 0) return;

    const handlers: Array<{ el: Element; fn: (e: Event) => void }> = [];
    toggles.forEach((toggle) => {
      const onClick = (e: Event) => {
        e.preventDefault();
        e.stopPropagation();
        const nav = toggle.closest('nav');
        const list = nav?.querySelector('[data-series-list]');
        const chevron = toggle.querySelector('[data-chevron]');
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        list?.classList.toggle('hidden');
        chevron?.classList.toggle('rotate-180');
      };
      toggle.addEventListener('click', onClick);
      handlers.push({ el: toggle, fn: onClick });
    });
    return () => handlers.forEach(({ el, fn }) => el.removeEventListener('click', fn));
  });
</script>
