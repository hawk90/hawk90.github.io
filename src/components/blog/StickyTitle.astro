---
/**
 * StickyTitle — fixed mini-header that fades in after the user has
 * scrolled past the article's <h1>. Reads scroll position directly
 * (no sentinel DOM insertion → no layout shift, no race with JS).
 *
 * Hidden by html.reading-mode via the CSS .hide-in-reading class.
 */

interface Props {
  title: string;
  series?: string;
  seriesOrder?: number;
  seriesTotal?: number;
}

const { title, series, seriesOrder, seriesTotal } = Astro.props;
---

<div
  id="sticky-title"
  class="hide-in-reading fixed top-0 left-0 right-0 z-40 pointer-events-none opacity-0 transition-opacity duration-200 ease-out"
  aria-hidden="true"
>
  <div class="pointer-events-auto bg-[color-mix(in_oklab,var(--color-bg-primary)_94%,transparent)] border-b border-[var(--color-border)] shadow-sm">
    <div class="container flex items-center gap-3 py-2.5">
      <a
        href="#main-content"
        class="shrink-0 w-8 h-8 inline-flex items-center justify-center rounded-md text-[var(--color-text-muted)] hover:bg-[var(--color-bg-secondary)] hover:text-[var(--color-text-primary)] transition-colors"
        aria-label="Back to top"
        data-sticky-top
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
        </svg>
      </a>
      <div class="min-w-0 flex-1">
        {series && (
          <div class="text-[10px] uppercase tracking-wider text-[var(--color-accent)] font-medium leading-none mb-0.5">
            {series}{seriesOrder && seriesTotal ? ` · ${seriesOrder}/${seriesTotal}` : ''}
          </div>
        )}
        <div class="text-sm font-semibold text-[var(--color-text-primary)] truncate">{title}</div>
      </div>
      {series && seriesOrder && seriesTotal && (
        <div class="hidden sm:block w-32 shrink-0">
          <div class="h-1 rounded-full bg-[var(--color-bg-tertiary)] overflow-hidden">
            <div
              class="h-full bg-[var(--color-accent)] rounded-full transition-[width] duration-300 ease-out"
              style={`width: ${(seriesOrder / seriesTotal) * 100}%`}
              aria-hidden="true"
            ></div>
          </div>
          <div class="text-[10px] text-[var(--color-text-muted)] text-right mt-0.5 leading-none tabular-nums">
            {seriesOrder} / {seriesTotal}
          </div>
        </div>
      )}
    </div>
    {/* The global .scroll-progress at the very top of the viewport
        already shows reading progress, so no sliver here — avoids
        the double-bar look once scrolled to 100%. */}
  </div>
</div>

<script>
  let stickyCleanup: (() => void) | null = null;

  function initStickyTitle() {
    stickyCleanup?.();

    const bar = document.getElementById('sticky-title');
    if (!bar) return;

    const articleHeader = document.querySelector<HTMLElement>('article header');

    let ticking = false;
    function update() {
      ticking = false;

      // Visibility: show after user scrolls past the bottom of the
      // article <header> (where the real h1 sits).
      let triggerY = 80;
      if (articleHeader) {
        const r = articleHeader.getBoundingClientRect();
        triggerY = r.bottom; // becomes <=0 when scrolled past
      }
      const visible = triggerY < 0;
      bar!.style.opacity = visible ? '1' : '0';
      bar!.setAttribute('aria-hidden', String(!visible));
    }
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    }
    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });

    const topBtn = bar.querySelector<HTMLAnchorElement>('[data-sticky-top]');
    function scrollTop(e: Event) {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    topBtn?.addEventListener('click', scrollTop);

    stickyCleanup = () => {
      window.removeEventListener('scroll', onScroll);
      window.removeEventListener('resize', onScroll);
      topBtn?.removeEventListener('click', scrollTop);
    };
  }

  initStickyTitle();
  document.addEventListener('astro:page-load', initStickyTitle);
</script>
