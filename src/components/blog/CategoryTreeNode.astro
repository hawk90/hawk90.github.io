---
interface SeriesLink {
  name: string;
  slug: string;
  count: number;
  isActive: boolean;
}

export interface CategoryTreeNodeData {
  id: string;
  name: string;
  icon: string;
  count: number;
  isActive: boolean;
  initiallyOpen: boolean;
  children: CategoryTreeNodeData[];
  series: SeriesLink[];
}

interface Props {
  node: CategoryTreeNodeData;
  depth?: number;
}

const { node, depth = 0 } = Astro.props;
const isNested = depth > 0;
const rowClass = isNested
  ? [
      'cat-row flex items-center gap-1 rounded text-sm transition-colors',
      node.isActive
        ? 'bg-[var(--color-accent)]/10 text-[var(--color-accent)] font-medium'
        : 'text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-secondary)] hover:text-[var(--color-accent)]',
    ]
  : [
      'cat-row flex items-center gap-1 rounded-lg transition-colors',
      node.isActive
        ? 'bg-[var(--color-accent)]/10 text-[var(--color-accent)]'
        : 'hover:bg-[var(--color-bg-secondary)]',
    ];
const toggleClass = isNested
  ? 'cat-toggle flex items-center gap-1 py-1.5 pl-2 pr-1 rounded-l cursor-pointer'
  : 'cat-toggle flex items-center gap-1 py-2 pl-2 pr-1 rounded-l-lg cursor-pointer';
const linkClass = isNested
  ? 'flex items-center justify-between flex-1 min-w-0 py-1.5 pr-2'
  : 'flex items-center justify-between flex-1 min-w-0 py-2 pr-2';
const iconClass = isNested ? 'text-xs' : undefined;
const childListClass = isNested
  ? 'ml-3 mt-1 space-y-0.5 border-l border-[var(--color-border)] pl-2'
  : 'ml-3 mt-1 space-y-1 border-l border-[var(--color-border)] pl-2';
const seriesLinkClass = isNested
  ? [
      'flex items-center justify-between w-full py-1 px-2 rounded text-xs transition-colors',
      'text-[var(--color-text-muted)] hover:bg-[var(--color-bg-secondary)] hover:text-[var(--color-accent)]',
    ]
  : [
      'flex items-center justify-between w-full py-1.5 px-2 rounded text-sm transition-colors',
      'text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-secondary)] hover:text-[var(--color-accent)]',
    ];
---

<details class="cat-tree" open={node.initiallyOpen}>
  <summary class:list={rowClass}>
    <button
      type="button"
      class={toggleClass}
      aria-expanded={node.initiallyOpen ? 'true' : 'false'}
    >
      <svg class="chevron w-3 h-3 shrink-0 text-[var(--color-text-muted)] transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
      </svg>
    </button>
    <a href={`/blog/${node.id}`} class={linkClass}>
      <span class="flex items-center gap-1.5 truncate">
        <span class={iconClass}>{node.icon}</span>
        <span class="truncate">{node.name}</span>
      </span>
      {node.count > 0 && <span class="text-xs text-[var(--color-text-muted)] ml-2 shrink-0">{node.count}</span>}
    </a>
  </summary>

  {node.children.length > 0 && (
    <ul class={childListClass}>
      {node.children.map((child) => (
        <li>
          <Astro.self node={child} depth={depth + 1} />
        </li>
      ))}
    </ul>
  )}

  {node.series.length > 0 && (
    <ul class={childListClass}>
      {node.series.map((series) => (
        <li>
          <a
            href={`/series/${series.slug}`}
            class:list={[
              ...seriesLinkClass,
              series.isActive && 'bg-[var(--color-accent)]/10 text-[var(--color-accent)] font-medium',
            ]}
          >
            <span class="truncate">{series.name}</span>
            <span class:list={['text-xs', isNested ? 'opacity-60' : 'text-[var(--color-text-muted)]']}>
              {series.count}
            </span>
          </a>
        </li>
      ))}
    </ul>
  )}
</details>
