---
import { CODE_THEMES } from '../../lib/theme';

const darkThemes = CODE_THEMES.filter(t => t.type === 'dark');
const lightThemes = CODE_THEMES.filter(t => t.type === 'light');
---

<div class="space-y-4">
  <!-- Site Mode Selector -->
  <div>
    <label class="block text-sm font-medium text-[var(--color-text-secondary)] mb-2">
      Site Mode
    </label>
    <div class="flex gap-2">
      <button
        type="button"
        id="modeDark"
        class="mode-btn flex-1 px-4 py-2.5 rounded-lg border transition-colors text-sm font-medium"
      >
        Dark
      </button>
      <button
        type="button"
        id="modeLight"
        class="mode-btn flex-1 px-4 py-2.5 rounded-lg border transition-colors text-sm font-medium"
      >
        Light
      </button>
    </div>
  </div>

  <!-- Code Theme Selector (independent of site mode) -->
  <div>
    <label class="block text-sm font-medium text-[var(--color-text-secondary)] mb-2">
      Code Block Theme
    </label>
    <select
      id="codeThemeSelect"
      class="w-full px-4 py-2.5 bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-lg text-[var(--color-text-primary)] focus:outline-none focus:border-[var(--color-accent)] cursor-pointer"
    >
      <optgroup label="Dark Themes">
        {darkThemes.map((theme) => (
          <option value={theme.id}>{theme.name}</option>
        ))}
      </optgroup>
      <optgroup label="Light Themes">
        {lightThemes.map((theme) => (
          <option value={theme.id}>{theme.name}</option>
        ))}
      </optgroup>
    </select>
  </div>

  <p class="text-sm text-[var(--color-text-muted)]">
    Settings are saved automatically and applied across the site.
  </p>
</div>

<style>
  .mode-btn {
    background-color: var(--color-bg-secondary);
    border-color: var(--color-border);
    color: var(--color-text-secondary);
  }
  .mode-btn:hover {
    border-color: var(--color-border-hover);
  }
  .mode-btn.active {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }
</style>

<script>
  import { getStoredCodeTheme, setStoredCodeTheme, setStoredTheme, syncCodeTheme } from '../../lib/theme';
  import { onPageLoad } from '../../lib/lifecycle';

  onPageLoad(() => {
    const modeDark = document.getElementById('modeDark') as HTMLButtonElement | null;
    const modeLight = document.getElementById('modeLight') as HTMLButtonElement | null;
    const codeThemeSelect = document.getElementById('codeThemeSelect') as HTMLSelectElement | null;
    if (!modeDark || !modeLight || !codeThemeSelect) return;

    // Initialize code theme dropdown
    codeThemeSelect.value = getStoredCodeTheme();

    const applyPreview = () => {
      const html = document.documentElement;
      html.setAttribute('data-code-theme', codeThemeSelect.value);
      syncCodeTheme();
    };

    const setMode = (mode: 'dark' | 'light') => {
      const html = document.documentElement;
      html.classList.toggle('light', mode === 'light');
      modeDark.classList.toggle('active', mode === 'dark');
      modeLight.classList.toggle('active', mode === 'light');
      setStoredTheme(mode);
      window.dispatchEvent(new CustomEvent('theme-mode-changed'));
    };

    const onDarkMode = () => setMode('dark');
    const onLightMode = () => setMode('light');
    const onCodeThemeChange = () => {
      setStoredCodeTheme(codeThemeSelect.value);
      applyPreview();
      window.dispatchEvent(new CustomEvent('settings-changed'));
    };

    modeDark.addEventListener('click', onDarkMode);
    modeLight.addEventListener('click', onLightMode);
    codeThemeSelect.addEventListener('change', onCodeThemeChange);

    // Initialize mode buttons
    const isLight = document.documentElement.classList.contains('light');
    modeDark.classList.toggle('active', !isLight);
    modeLight.classList.toggle('active', isLight);

    return () => {
      modeDark.removeEventListener('click', onDarkMode);
      modeLight.removeEventListener('click', onLightMode);
      codeThemeSelect.removeEventListener('change', onCodeThemeChange);
    };
  });
</script>
