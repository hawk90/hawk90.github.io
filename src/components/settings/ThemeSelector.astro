---
import { CODE_THEMES } from '../../lib/theme';
---

<div class="space-y-4">
  <!-- Mode Selector -->
  <div>
    <label class="block text-sm font-medium text-[var(--color-text-secondary)] mb-2">
      Mode
    </label>
    <div class="flex gap-2">
      <button
        type="button"
        id="modeDark"
        class="mode-btn flex-1 px-4 py-2.5 rounded-lg border transition-colors text-sm font-medium"
      >
        Dark Mode
      </button>
      <button
        type="button"
        id="modeLight"
        class="mode-btn flex-1 px-4 py-2.5 rounded-lg border transition-colors text-sm font-medium"
      >
        Light Mode
      </button>
    </div>
  </div>

  <!-- Theme Selector -->
  <div>
    <label class="block text-sm font-medium text-[var(--color-text-secondary)] mb-2">
      Theme
    </label>

    <!-- Dark themes -->
    <select
      id="darkThemeSelect"
      class="hidden w-full px-4 py-2.5 bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-lg text-[var(--color-text-primary)] focus:outline-none focus:border-[var(--color-accent)] cursor-pointer"
    >
      {CODE_THEMES.dark.map((theme) => (
        <option value={theme.id}>{theme.name}</option>
      ))}
    </select>

    <!-- Light themes -->
    <select
      id="lightThemeSelect"
      class="hidden w-full px-4 py-2.5 bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-lg text-[var(--color-text-primary)] focus:outline-none focus:border-[var(--color-accent)] cursor-pointer"
    >
      {CODE_THEMES.light.map((theme) => (
        <option value={theme.id}>{theme.name}</option>
      ))}
    </select>
  </div>

  <p class="text-sm text-[var(--color-text-muted)]">
    Settings are saved automatically and applied across the site.
  </p>
</div>

<style>
  .mode-btn {
    background-color: var(--color-bg-secondary);
    border-color: var(--color-border);
    color: var(--color-text-secondary);
  }
  .mode-btn:hover {
    border-color: var(--color-border-hover);
  }
  .mode-btn.active {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }
</style>

<script>
  import { getStoredCodeTheme, setStoredCodeTheme, setStoredTheme, syncCodeTheme } from '../../lib/theme';
  import { onPageLoad } from '../../lib/lifecycle';

  onPageLoad(() => {
    const modeDark = document.getElementById('modeDark') as HTMLButtonElement | null;
    const modeLight = document.getElementById('modeLight') as HTMLButtonElement | null;
    const darkSelect = document.getElementById('darkThemeSelect') as HTMLSelectElement | null;
    const lightSelect = document.getElementById('lightThemeSelect') as HTMLSelectElement | null;
    if (!modeDark || !modeLight || !darkSelect || !lightSelect) return;

    let currentMode: 'dark' | 'light' = 'dark';
    darkSelect.value = getStoredCodeTheme('dark');
    lightSelect.value = getStoredCodeTheme('light');

    const applyPreview = () => {
      const html = document.documentElement;
      const isLight = currentMode === 'light';
      html.classList.toggle('light', isLight);
      html.setAttribute('data-code-theme', isLight ? lightSelect.value : darkSelect.value);
      setStoredTheme(currentMode);
      syncCodeTheme();
      window.dispatchEvent(new CustomEvent('theme-mode-changed'));
    };

    const setMode = (mode: 'dark' | 'light') => {
      currentMode = mode;
      modeDark.classList.toggle('active', mode === 'dark');
      modeLight.classList.toggle('active', mode === 'light');
      darkSelect.classList.toggle('hidden', mode !== 'dark');
      lightSelect.classList.toggle('hidden', mode !== 'light');
      applyPreview();
    };

    const onDarkMode = () => setMode('dark');
    const onLightMode = () => setMode('light');
    const onDarkChange = () => { setStoredCodeTheme('dark', darkSelect.value); applyPreview(); window.dispatchEvent(new CustomEvent('settings-changed')); };
    const onLightChange = () => { setStoredCodeTheme('light', lightSelect.value); applyPreview(); window.dispatchEvent(new CustomEvent('settings-changed')); };

    modeDark.addEventListener('click', onDarkMode);
    modeLight.addEventListener('click', onLightMode);
    darkSelect.addEventListener('change', onDarkChange);
    lightSelect.addEventListener('change', onLightChange);

    setMode(document.documentElement.classList.contains('light') ? 'light' : 'dark');

    return () => {
      modeDark.removeEventListener('click', onDarkMode);
      modeLight.removeEventListener('click', onLightMode);
      darkSelect.removeEventListener('change', onDarkChange);
      lightSelect.removeEventListener('change', onLightChange);
    };
  });
</script>
