---
---

<div class="code-preview">
  <div class="flex flex-wrap gap-2 mb-3">
    <button
      type="button"
      data-lang="cpp"
      class="lang-tab px-3 py-1.5 text-sm rounded-lg transition-colors bg-[var(--color-accent)] text-white"
    >
      C++
    </button>
    <button
      type="button"
      data-lang="python"
      class="lang-tab px-3 py-1.5 text-sm rounded-lg transition-colors bg-[var(--color-bg-tertiary)] text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-secondary)]"
    >
      Python
    </button>
    <button
      type="button"
      data-lang="typescript"
      class="lang-tab px-3 py-1.5 text-sm rounded-lg transition-colors bg-[var(--color-bg-tertiary)] text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-secondary)]"
    >
      TypeScript
    </button>
    <button
      type="button"
      data-lang="rust"
      class="lang-tab px-3 py-1.5 text-sm rounded-lg transition-colors bg-[var(--color-bg-tertiary)] text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-secondary)]"
    >
      Rust
    </button>
  </div>

  <div class="code-panels">
    <div data-panel="cpp" class="code-panel">
      <slot name="cpp" />
    </div>
    <div data-panel="python" class="code-panel hidden">
      <slot name="python" />
    </div>
    <div data-panel="typescript" class="code-panel hidden">
      <slot name="typescript" />
    </div>
    <div data-panel="rust" class="code-panel hidden">
      <slot name="rust" />
    </div>
  </div>
</div>

<script>
  import { onPageLoad } from '../../lib/lifecycle';

  onPageLoad(() => {
    const tabs = document.querySelectorAll('.lang-tab');
    const panels = document.querySelectorAll('.code-panel');
    if (tabs.length === 0) return;

    const handlers: Array<{ tab: Element; fn: () => void }> = [];
    tabs.forEach((tab) => {
      const onClick = () => {
        const lang = tab.getAttribute('data-lang');
        tabs.forEach((t) => {
          const active = t.getAttribute('data-lang') === lang;
          t.classList.toggle('bg-[var(--color-accent)]', active);
          t.classList.toggle('text-white', active);
          t.classList.toggle('bg-[var(--color-bg-tertiary)]', !active);
          t.classList.toggle('text-[var(--color-text-secondary)]', !active);
        });
        panels.forEach((p) => {
          p.classList.toggle('hidden', p.getAttribute('data-panel') !== lang);
        });
      };
      tab.addEventListener('click', onClick);
      handlers.push({ tab, fn: onClick });
    });
    return () => handlers.forEach(({ tab, fn }) => tab.removeEventListener('click', fn));
  });
</script>
