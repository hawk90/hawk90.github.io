---
import '../styles/global.css';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import ScrollProgress from '../components/ui/ScrollProgress.astro';
import SearchModal from '../components/common/SearchModal.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  showProgress?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  noIndex?: boolean;
}

const {
  title,
  description = 'Developer blog about C++, tech books, and software engineering',
  image = '/og-default.png',
  type = 'website',
  showProgress = false,
  publishedTime,
  modifiedTime,
  author = 'Hawk',
  noIndex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);
---

<!doctype html>
<html lang="ko" data-code-theme="github-dark-dimmed">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Hawk's Blog" />
    <meta property="og:locale" content="ko_KR" />

    {type === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime.toISOString()} />
    )}
    {type === 'article' && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime.toISOString()} />
    )}
    {type === 'article' && author && (
      <meta property="article:author" content={author} />
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- KaTeX CSS -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
      integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
      crossorigin="anonymous"
    />

    <!-- Fonts -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />

    <!-- Theme initialization (prevent flash) -->
    <script is:inline>
      (function() {
        try {
          const theme = localStorage.getItem('theme');
          if (theme === 'light') {
            document.documentElement.classList.add('light');
          } else if (theme === 'dark') {
            document.documentElement.classList.remove('light');
          } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
            document.documentElement.classList.add('light');
          }

          // Code theme initialization
          const isLight = document.documentElement.classList.contains('light');
          const darkCodeTheme = localStorage.getItem('code-theme-dark') || 'github-dark-dimmed';
          const lightCodeTheme = localStorage.getItem('code-theme-light') || 'github-light';
          document.documentElement.setAttribute('data-code-theme', isLight ? lightCodeTheme : darkCodeTheme);

          // Line numbers initialization (default: true)
          const showLineNumbers = localStorage.getItem('show-line-numbers');
          document.documentElement.setAttribute('data-show-line-numbers', showLineNumbers !== 'false' ? 'true' : 'false');
        } catch {
          // Access to localStorage might be restricted; fall back to system preference
          if (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) {
            document.documentElement.classList.add('light');
          }
          document.documentElement.setAttribute('data-code-theme', document.documentElement.classList.contains('light') ? 'github-light' : 'github-dark-dimmed');
          document.documentElement.setAttribute('data-show-line-numbers', 'true');
        }
      })();
    </script>

    <!-- View Transitions -->
    <meta name="view-transition" content="same-origin" />

    <!-- Re-apply theme after View Transition swap -->
    <script is:inline>
      document.addEventListener('astro:after-swap', function() {
        try {
          var theme = localStorage.getItem('theme');
          if (theme === 'light') {
            document.documentElement.classList.add('light');
          } else if (theme === 'dark') {
            document.documentElement.classList.remove('light');
          } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
            document.documentElement.classList.add('light');
          } else {
            document.documentElement.classList.remove('light');
          }

          var isLight = document.documentElement.classList.contains('light');
          var darkCodeTheme = localStorage.getItem('code-theme-dark') || 'github-dark-dimmed';
          var lightCodeTheme = localStorage.getItem('code-theme-light') || 'github-light';
          document.documentElement.setAttribute('data-code-theme', isLight ? lightCodeTheme : darkCodeTheme);

          var showLineNumbers = localStorage.getItem('show-line-numbers');
          document.documentElement.setAttribute('data-show-line-numbers', showLineNumbers !== 'false' ? 'true' : 'false');
        } catch(e) {}
      });
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    {showProgress && <ScrollProgress />}
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <SearchModal />

    <!-- Keyboard Shortcuts Help Modal -->
    <div id="shortcuts-modal" class="fixed inset-0 z-[100] hidden" role="dialog" aria-modal="true" aria-label="키보드 단축키">
      <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-shortcuts-backdrop></div>
      <div class="relative flex items-center justify-center min-h-screen px-4">
        <div class="w-full max-w-sm bg-[var(--color-bg-primary)] border border-[var(--color-border)] rounded-xl shadow-2xl p-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold">키보드 단축키</h2>
            <button type="button" data-shortcuts-close class="p-1 text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] rounded-lg" aria-label="닫기">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>
          <dl class="space-y-3 text-sm">
            <div class="flex justify-between">
              <dt class="text-[var(--color-text-secondary)]">검색 열기</dt>
              <dd><kbd class="px-2 py-0.5 bg-[var(--color-bg-tertiary)] rounded border border-[var(--color-border)] text-xs">/</kbd></dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-[var(--color-text-secondary)]">이 도움말 보기</dt>
              <dd><kbd class="px-2 py-0.5 bg-[var(--color-bg-tertiary)] rounded border border-[var(--color-border)] text-xs">?</kbd></dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-[var(--color-text-secondary)]">모달 닫기</dt>
              <dd><kbd class="px-2 py-0.5 bg-[var(--color-bg-tertiary)] rounded border border-[var(--color-border)] text-xs">Esc</kbd></dd>
            </div>
          </dl>
        </div>
      </div>
    </div>

    <!-- Keyboard shortcuts -->
    <script>
      function initShortcuts() {
        const shortcutsModal = document.getElementById('shortcuts-modal');
        const shortcutsBackdrop = document.querySelector('[data-shortcuts-backdrop]');
        const shortcutsClose = document.querySelector('[data-shortcuts-close]');

        function closeShortcutsModal() {
          shortcutsModal?.classList.add('hidden');
          document.body.style.overflow = '';
        }

        function openShortcutsModal() {
          shortcutsModal?.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        }

        shortcutsBackdrop?.addEventListener('click', closeShortcutsModal);
        shortcutsClose?.addEventListener('click', closeShortcutsModal);

        document.addEventListener('keydown', (e) => {
          if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;

          if (e.key === 'Escape') {
            if (shortcutsModal && !shortcutsModal.classList.contains('hidden')) {
              closeShortcutsModal();
              return;
            }
            const activeElement = document.activeElement as HTMLElement;
            activeElement?.blur();
          }

          if (e.key === '?' && !e.ctrlKey && !e.metaKey) {
            if (shortcutsModal?.classList.contains('hidden')) {
              e.preventDefault();
              openShortcutsModal();
            }
          }
        });
      }

      initShortcuts();
      document.addEventListener('astro:page-load', initShortcuts);
    </script>
  </body>
</html>
