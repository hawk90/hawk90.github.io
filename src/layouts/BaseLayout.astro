---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import ScrollProgress from '../components/ui/ScrollProgress.astro';
import BackToTop from '../components/ui/BackToTop.astro';
import SearchModal from '../components/common/SearchModal.astro';
import { SITE_CONFIG, ANALYTICS_CONFIG } from '../consts/config';
import { t } from '../consts/ui-strings';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  showProgress?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  noIndex?: boolean;
  noFollow?: boolean;
  canonical?: string;
  hasMath?: boolean;
}

const {
  title,
  description = SITE_CONFIG.description,
  image = '/og-default.png',
  type = 'website',
  showProgress = false,
  publishedTime,
  modifiedTime,
  author = SITE_CONFIG.author,
  noIndex = false,
  noFollow = false,
  canonical,
  hasMath = false,
} = Astro.props;

const canonicalURL = canonical
  ? new URL(canonical)
  : new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);
const robotsValue = [noIndex && 'noindex', noFollow && 'nofollow']
  .filter(Boolean)
  .join(', ');
const ogLocale = SITE_CONFIG.locale.replace('-', '_');

// JSON-LD structured data
const jsonLd = type === 'article'
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      image: ogImageURL.toString(),
      url: canonicalURL.toString(),
      datePublished: publishedTime?.toISOString(),
      dateModified: modifiedTime?.toISOString() || publishedTime?.toISOString(),
      author: {
        '@type': 'Person',
        name: author,
      },
      publisher: {
        '@type': 'Organization',
        name: SITE_CONFIG.title,
        url: SITE_CONFIG.url,
      },
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: SITE_CONFIG.title,
      description: SITE_CONFIG.description,
      url: SITE_CONFIG.url,
    };
---

<!doctype html>
<html lang={SITE_CONFIG.lang} data-code-theme="github-dark-dimmed">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Security -->
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Content-Security-Policy" content={[
      "default-src 'self'",
      // 'unsafe-inline' required for is:inline theme scripts (FOUC prevention).
      // define:vars has been eliminated from all components (Giscus, SearchModal).
      // GitHub domains added for admin panel OAuth and API access.
      "script-src 'self' 'unsafe-inline' https://giscus.app" + (ANALYTICS_CONFIG.enabled && ANALYTICS_CONFIG.provider === 'google' ? ' https://www.googletagmanager.com https://www.google-analytics.com' : '') + (ANALYTICS_CONFIG.enabled && ANALYTICS_CONFIG.provider === 'umami' ? ` ${ANALYTICS_CONFIG.src || 'https://analytics.umami.is'}` : '') + (ANALYTICS_CONFIG.enabled && ANALYTICS_CONFIG.provider === 'plausible' ? ' https://plausible.io' : ''),
      "style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net",
      "font-src 'self' https://cdn.jsdelivr.net",
      "img-src 'self' data: https:",
      "connect-src 'self' https://giscus.app https://api.github.com https://github.com" + (ANALYTICS_CONFIG.enabled && ANALYTICS_CONFIG.provider === 'google' ? ' https://www.google-analytics.com' : '') + (ANALYTICS_CONFIG.enabled && ANALYTICS_CONFIG.provider === 'umami' ? ` ${ANALYTICS_CONFIG.src || 'https://analytics.umami.is'}` : '') + (ANALYTICS_CONFIG.enabled && ANALYTICS_CONFIG.provider === 'plausible' ? ' https://plausible.io' : ''),
      "frame-src https://giscus.app",
      "object-src 'none'",
      "base-uri 'self'",
      "form-action 'self' https://github.com",
    ].join('; ')} />

    <!-- Google AdSense site-ownership verification -->
    <meta name="google-adsense-account" content="ca-pub-6238136533844790" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    {robotsValue && <meta name="robots" content={robotsValue} />}

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={SITE_CONFIG.title} />
    <meta property="og:locale" content={ogLocale} />

    {type === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime.toISOString()} />
    )}
    {type === 'article' && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime.toISOString()} />
    )}
    {type === 'article' && author && (
      <meta property="article:author" content={author} />
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- JSON-LD Structured Data (escape </ to prevent script breakout) -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />

    <!-- Analytics -->
    {ANALYTICS_CONFIG.enabled && ANALYTICS_CONFIG.provider === 'google' && ANALYTICS_CONFIG.id && (
      <>
        <script async crossorigin="anonymous" src={`https://www.googletagmanager.com/gtag/js?id=${ANALYTICS_CONFIG.id}`}></script>
        <script is:inline data-ga-id={ANALYTICS_CONFIG.id}>
          window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag("js",new Date());gtag("config",document.currentScript.getAttribute("data-ga-id"));
        </script>
      </>
    )}
    {ANALYTICS_CONFIG.enabled && ANALYTICS_CONFIG.provider === 'umami' && ANALYTICS_CONFIG.id && (
      <script async defer crossorigin="anonymous" data-website-id={ANALYTICS_CONFIG.id} src={ANALYTICS_CONFIG.src || 'https://analytics.umami.is/script.js'}></script>
    )}
    {ANALYTICS_CONFIG.enabled && ANALYTICS_CONFIG.provider === 'plausible' && ANALYTICS_CONFIG.id && (
      <script async defer crossorigin="anonymous" data-domain={ANALYTICS_CONFIG.id} src="https://plausible.io/js/script.js"></script>
    )}

    {/* KaTeX CSS — only on pages with math content */}
    {hasMath && (
      <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
        integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
        crossorigin="anonymous"
      />
    )}

    {/* Fonts — Pretendard via CDN dynamic subset (Korean unicode-range optimized).
        JetBrains Mono self-hosted (see /src/styles/global.css @font-face). */}
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
      crossorigin="anonymous"
    />
    <link rel="preload" href="/fonts/JetBrainsMono-Variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

    <!-- Clickjacking protection (frame-busting) -->
    <script is:inline>
      if(window.top!==window.self){window.top.location=window.self.location}
    </script>

    <!--
      Theme initialization — render-blocking to prevent FOUC.
      This inline IIFE intentionally duplicates the localStorage read +
      class/attribute write that `lib/theme.ts → applyTheme` does. The
      duplication is the price of pre-paint execution: we cannot import a
      module from an inline script. The two stay in sync via the
      VALID_CODE_THEMES constant and STORAGE_KEYS object that both sides
      consume — change the keys in one place only.
    -->
    <script is:inline>
      (function(){
        try{
          var V=["github-dark-dimmed","github-light","dracula","one-dark-pro","catppuccin-mocha","catppuccin-latte","nord","tokyo-night"];
          var el=document.documentElement, t=localStorage.getItem("theme");
          var pref=window.matchMedia&&window.matchMedia("(prefers-color-scheme: light)").matches;
          var light=t==="light"||(t!=="dark"&&pref);
          el.classList.toggle("light",light);
          var c=localStorage.getItem("code-theme"); if(V.indexOf(c)===-1) c="github-dark-dimmed";
          el.setAttribute("data-code-theme",c);
          var n=localStorage.getItem("show-line-numbers");
          el.setAttribute("data-show-line-numbers",n!=="false"?"true":"false");
          if(localStorage.getItem("reading-mode")==="1") el.classList.add("reading-mode");
          // Theme customizer pre-paint
          var f=localStorage.getItem("font-family");   if(f) el.setAttribute("data-font",f);
          var dn=localStorage.getItem("ui-density");   if(dn) el.setAttribute("data-density",dn);
          var ac=localStorage.getItem("accent-color"); if(ac) el.setAttribute("data-accent",ac);
        }catch(e){}
      })();
    </script>

    <!-- SPA-style navigation with cross-document fallback -->
    <ClientRouter />

    <!-- Reactive theme wiring (before-swap, after-swap, pageshow,
         astro:page-load, storage). All handlers live in lib/theme.ts. -->
    <script>
      import { installThemeReactivity, syncCodeTheme } from '../lib/theme';
      installThemeReactivity();
      syncCodeTheme();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Skip to content (accessibility) -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[200] focus:px-4 focus:py-2 focus:bg-[var(--color-accent)] focus:text-white focus:rounded-lg focus:text-sm focus:font-medium">
      {t('skip_to_content')}
    </a>
    {showProgress && <ScrollProgress />}
    <Header transition:persist="header" />
    <main id="main-content" class="flex-1" transition:animate="fade">
      <slot />
    </main>
    <Footer />
    <BackToTop />
    <SearchModal />

    <!-- Keyboard Shortcuts Help Modal -->
    <div id="shortcuts-modal" class="fixed inset-0 z-[100] hidden" role="dialog" aria-modal="true" aria-label={t('keyboard_shortcuts')}>
      <div class="absolute inset-0 bg-black/72" data-shortcuts-backdrop></div>
      <div class="relative flex items-center justify-center min-h-screen px-4">
        <div class="w-full max-w-sm bg-[var(--color-bg-primary)] border border-[var(--color-border)] rounded-xl shadow-2xl p-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold">{t('keyboard_shortcuts')}</h2>
            <button type="button" data-shortcuts-close class="p-1 text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] rounded-lg" aria-label={t('search_close')}>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>
          <dl class="space-y-3 text-sm">
            <div class="flex justify-between">
              <dt class="text-[var(--color-text-secondary)]">{t('shortcut_open_search')}</dt>
              <dd><kbd class="px-2 py-0.5 bg-[var(--color-bg-tertiary)] rounded border border-[var(--color-border)] text-xs">/</kbd></dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-[var(--color-text-secondary)]">{t('shortcut_help')}</dt>
              <dd><kbd class="px-2 py-0.5 bg-[var(--color-bg-tertiary)] rounded border border-[var(--color-border)] text-xs">?</kbd></dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-[var(--color-text-secondary)]">{t('shortcut_close_modal')}</dt>
              <dd><kbd class="px-2 py-0.5 bg-[var(--color-bg-tertiary)] rounded border border-[var(--color-border)] text-xs">Esc</kbd></dd>
            </div>
          </dl>
        </div>
      </div>
    </div>

    <!-- Keyboard shortcuts -->
    <script>
      let shortcutsCleanup: (() => void) | null = null;

      function initShortcuts() {
        shortcutsCleanup?.();

        const shortcutsModal = document.getElementById('shortcuts-modal');
        const shortcutsBackdrop = document.querySelector('[data-shortcuts-backdrop]');
        const shortcutsClose = document.querySelector('[data-shortcuts-close]');

        function closeShortcutsModal() {
          shortcutsModal?.classList.add('hidden');
          document.body.style.overflow = '';
        }

        function openShortcutsModal() {
          shortcutsModal?.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        }

        function handleKeydown(e: KeyboardEvent) {
          if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;

          if (e.key === 'Escape') {
            if (shortcutsModal && !shortcutsModal.classList.contains('hidden')) {
              closeShortcutsModal();
              return;
            }
            const activeElement = document.activeElement as HTMLElement;
            activeElement?.blur();
          }

          if (e.key === '?' && !e.ctrlKey && !e.metaKey) {
            if (shortcutsModal?.classList.contains('hidden')) {
              e.preventDefault();
              openShortcutsModal();
            }
          }
        }

        shortcutsBackdrop?.addEventListener('click', closeShortcutsModal);
        shortcutsClose?.addEventListener('click', closeShortcutsModal);
        document.addEventListener('keydown', handleKeydown);

        shortcutsCleanup = () => {
          shortcutsBackdrop?.removeEventListener('click', closeShortcutsModal);
          shortcutsClose?.removeEventListener('click', closeShortcutsModal);
          document.removeEventListener('keydown', handleKeydown);
        };
      }

      initShortcuts();
      document.addEventListener('astro:page-load', initShortcuts);
    </script>

    <!-- Image lightbox (click any <img> inside .prose to expand) -->
    <script>
      let lightboxCleanup: (() => void) | null = null;
      function initLightbox() {
        lightboxCleanup?.();
        const images = document.querySelectorAll<HTMLImageElement>('.prose img:not(.no-zoom)');
        if (images.length === 0) return;

        const overlay = document.createElement('div');
        overlay.className = 'lightbox-overlay';
        overlay.setAttribute('role', 'dialog');
        overlay.setAttribute('aria-modal', 'true');
        overlay.setAttribute('aria-label', 'Expanded image');
        overlay.dataset.open = 'false';
        overlay.style.display = 'none';
        const inner = document.createElement('img');
        inner.alt = '';
        overlay.appendChild(inner);
        document.body.appendChild(overlay);

        function close() {
          overlay.dataset.open = 'false';
          document.body.style.overflow = '';
          setTimeout(() => { overlay.style.display = 'none'; }, 200);
        }
        function open(src: string, alt: string) {
          inner.src = src;
          inner.alt = alt;
          overlay.style.display = 'flex';
          requestAnimationFrame(() => { overlay.dataset.open = 'true'; });
          document.body.style.overflow = 'hidden';
        }
        function onImgClick(e: Event) {
          const img = e.currentTarget as HTMLImageElement;
          open(img.currentSrc || img.src, img.alt);
        }
        function onKey(e: KeyboardEvent) {
          if (e.key === 'Escape' && overlay.dataset.open === 'true') close();
        }
        images.forEach((img) => img.addEventListener('click', onImgClick));
        overlay.addEventListener('click', close);
        document.addEventListener('keydown', onKey);

        lightboxCleanup = () => {
          images.forEach((img) => img.removeEventListener('click', onImgClick));
          overlay.removeEventListener('click', close);
          document.removeEventListener('keydown', onKey);
          overlay.remove();
        };
      }
      initLightbox();
      document.addEventListener('astro:page-load', initLightbox);
    </script>
  </body>
</html>
