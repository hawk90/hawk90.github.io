---
import BaseLayout from '../layouts/BaseLayout.astro';
import { USES_DATA } from '../consts/uses';
---

<BaseLayout title="Uses" description="The hardware, software, and workflow behind this site.">
  <section class="py-16">
    <div class="container">
      <div class="container-narrow mx-auto px-0">
        <div class="section-eyebrow mb-2">Uses</div>
        <h1 class="text-3xl lg:text-4xl font-bold leading-tight mb-3">What I use</h1>
        <p class="text-[var(--color-text-secondary)] mb-12">
          Gear and software behind this site — kept current in the spirit of
          <a href="https://uses.tech" target="_blank" rel="noopener noreferrer" class="underline hover:text-[var(--color-accent)]">
            uses.tech
          </a>.
        </p>

        <div class="grid gap-10 md:grid-cols-2">
          {USES_DATA.sections.map((section) => (
            <section class="card card-panel">
              <h2 class="sidebar-section-title mb-4">
                {section.title}
              </h2>
              <ul class="space-y-3">
                {section.items.map((item) => (
                  <li>
                    <div class="font-medium">{item.name}</div>
                    {item.detail && (
                      <div class="text-sm text-[var(--color-text-secondary)] mt-0.5">{item.detail}</div>
                    )}
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
