        period: '2024.03 ~ 2024.09',
        role: 'ROM/RAM code develop and porting SDK',
        skills: ['C++', 'Python', 'Arm M0+', 'Arm A53', 'Zebu', 'HAPS'],
        highlights: [
          'Developed an automated deployment script for Zebu and HAPS platform',
          'Developed ROM/RAM code on ARM',
          'Porting SDK on ARM',
