      },
    ],
  },
];

const skills = {
  'Programming Languages': ['C/C++', 'Python'],
  'Framework': ['TensorFlow', 'CUDA', 'MPI'],
  'Infra': ['Docker'],
  'OS': ['Linux (Ubuntu, CentOS)'],
  'Cloud': ['OpenStack', 'Eucalyptus'],
  'Data/DB': ['MySQL', 'MongoDB'],
  'Tools': ['Git', 'SVN', 'VIM'],
};

const education = [
  {
    institution: 'Korea University',
    degree: 'Integrated Ph.D. Candidate',
    field: 'School of Electrical Engineering',
    period: '2013.03 ~ 2018.12',
    gpa: '3.96/4.5',
    description: 'Research Area: Parallel/Distributed System, Deep Learning Optimization (Advisor: Prof. Chang-Sung Jeong)',
  },
  {
    institution: 'Sangmyung University',
    degree: 'B.S.',
    field: 'Department of Computer System Engineering',
    period: '2009.03 ~ 2013.02',
    gpa: '4.22/4.5',
  },
];

const publications = [
  {
    type: 'paper',
    title: 'Improving HDFS performance using local caching system',
    authors: 'Sang-Deok Yoon, In-Yong Jung, Ki-Hyun Kim, Chang-Sung Jeong',
    venue: 'Second International Conference on Future Generation Communication Technologies (FGCT 2013)',
    year: '2013',
  },
  {
    type: 'paper',
    title: 'Cloud based Distributed Active Content Repository',
    authors: 'Ki-Hyun Kim, In-Yong Jung, Sang-Deok Yoon, Yoon-Ki Kim, Chang-Sung Jeong',
    venue: '대한전자공학회 학술대회',
    year: '2014',
  },
  {
    type: 'paper',
    title: 'Active Content Repository based Distribution Local Cache System',
    authors: 'Sang-Deok Yoon, Chang-Sung Jeong',
    venue: '대한전자공학회 학술대회',
    year: '2015',
  },
  {
    type: 'patent',
    title: 'Method for volume rendering using parallel shear-warp factorization',
    authors: 'Chang-Sung Jeong, Ki-Hyun Kim, Su-Hyun Kim, Yoon-Ki Kim, In-Kyu Son, Sang-Deok Yoon, et al.',
    venue: 'KR Patent 10-2013-0147491',
    year: '2013',
  },
  {
    type: 'patent',
    title: 'Data comparing processing method and system in cloud computing environment',
    authors: 'Chang-Sung Jeong, Ki-Hyun Kim, Su-Hyun Kim, Yoon-Ki Kim, In-Kyu Son, Sang-Deok Yoon, et al.',
    venue: 'KR Patent 10-2013-0147492',
    year: '2013',
  },
  {
    type: 'patent',
    title: 'Face Recognition Method and System for Intelligent Surveillance',
    authors: 'Chang-Sung Jeong, Ki-Hyun Kim, Su-Hyun Kim, Yoon-Ki Kim, In-Kyu Son, Sang-Deok Yoon, et al.',
    venue: 'KR Patent 10-2013-0147498',
    year: '2013',
  },
];

const additionalExperience = [
  { role: 'Teaching Assistant', course: 'KECE208: Data Structure and Algorithm', period: '2015 Semester 2' },
  { role: 'Teaching Assistant', course: 'KECE317: Parallel Computing', period: '2016 Semester 1' },
  { role: 'Teaching Assistant', course: 'KECE208: Data Structure and Algorithm', period: '2016 Semester 2' },
  { role: 'Teaching Assistant', course: 'KECE317: Parallel Computing', period: '2017 Semester 1' },
  { role: 'Teaching Assistant', course: 'KECE208: Data Structure and Algorithm', period: '2017 Semester 2' },
  { role: 'Presenter', course: 'How to Train Deep Learning Model on Distributed and/or Multi-GPU Environment', period: '2017 Feb.', link: 'https://www.youtube.com/watch?v=DEfWtVJjtws' },
];
---

<BaseLayout title="Resume - Sang-Deok Yoon" description="Software Engineer with expertise in C++, CUDA, and parallel computing">
  <section class="py-16">
    <div class="container-narrow">
      <!-- Header -->
      <header class="mb-16 text-center">
        <h1 class="text-4xl font-bold mb-2">윤상덕</h1>
        <p class="text-2xl text-[var(--color-text-secondary)] mb-2">Sang-Deok Yoon</p>
        <p class="text-xl text-[var(--color-text-secondary)] mb-6">
          Software Engineer
        </p>
        <div class="flex justify-center gap-4">
          <a href="https://github.com/hawk90" class="btn btn-ghost" target="_blank" rel="noopener">
            GitHub
          </a>
          <a href="mailto:hawking90a@gmail.com" class="btn btn-ghost">
            Email
          </a>
          <button onclick="window.print()" class="btn btn-primary no-print">
            Print Resume
          </button>
        </div>
      </header>

      <!-- Core Competency -->
      <section class="mb-16">
        <h2 class="text-2xl font-bold mb-8 pb-2 border-b border-[var(--color-border)]">
          Core Competency
        </h2>
        <ul class="list-disc list-inside space-y-2 text-[var(--color-text-secondary)]">
          {coreCompetency.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <!-- Skills -->
      <section class="mb-16">
        <h2 class="text-2xl font-bold mb-8 pb-2 border-b border-[var(--color-border)]">
          Skills
        </h2>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {Object.entries(skills).map(([category, items]) => (
            <div class="card">
              <h3 class="text-sm font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-3">
                {category}
              </h3>
              <div class="flex flex-wrap gap-2">
                {items.map((skill) => (
                  <span class="tag">{skill}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Experience -->
      <section class="mb-16">
        <h2 class="text-2xl font-bold mb-8 pb-2 border-b border-[var(--color-border)]">
          Experience
        </h2>
        <div class="space-y-10">
          {experience.map((job) => (
            <div class="card">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 mb-6">
                <div>
                  <h3 class="text-xl font-semibold">{job.company}</h3>
                  <p class="text-[var(--color-accent)]">{job.position}</p>
                </div>
                <span class="text-sm text-[var(--color-text-muted)] whitespace-nowrap">{job.period}</span>
              </div>
              <div class="space-y-6">
                {job.projects.map((project) => (
                  <div class="border-l-2 border-[var(--color-border)] pl-4">
                    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-1 mb-2">
                      <h4 class="font-semibold">{project.name}</h4>
                      <span class="text-xs text-[var(--color-text-muted)]">{project.period}</span>
                    </div>
                    <p class="text-sm text-[var(--color-text-muted)] mb-2">Role: {project.role}</p>
                    <div class="flex flex-wrap gap-1 mb-3">
                      {project.skills.map((skill) => (
                        <span class="text-xs px-2 py-0.5 bg-[var(--color-bg-secondary)] rounded">{skill}</span>
                      ))}
                    </div>
                    <ul class="list-disc list-inside space-y-1 text-sm text-[var(--color-text-secondary)]">
                      {project.highlights.map((highlight) => (
                        <li>{highlight}</li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Education -->
      <section class="mb-16">
        <h2 class="text-2xl font-bold mb-8 pb-2 border-b border-[var(--color-border)]">
          Education
        </h2>
        <div class="space-y-6">
          {education.map((edu) => (
            <div class="card">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2">
                <div>
                  <h3 class="text-lg font-semibold">{edu.degree}</h3>
                  <p class="text-[var(--color-accent)]">{edu.institution}</p>
                  <p class="text-[var(--color-text-secondary)]">{edu.field}</p>
                  {edu.gpa && <p class="text-sm text-[var(--color-text-muted)]">GPA: {edu.gpa}</p>}
                  {edu.description && <p class="text-sm text-[var(--color-text-secondary)] mt-2">{edu.description}</p>}
                </div>
                <span class="text-sm text-[var(--color-text-muted)] whitespace-nowrap">{edu.period}</span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Publications -->
      <section class="mb-16">
        <h2 class="text-2xl font-bold mb-8 pb-2 border-b border-[var(--color-border)]">
          Publications & Patents
        </h2>
        <div class="space-y-4">
          {publications.map((pub) => (
            <div class="card">
              <span class={`inline-block text-xs px-2 py-0.5 rounded mb-2 ${pub.type === 'paper' ? 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200' : 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200'}`}>
                {pub.type === 'paper' ? 'Paper' : 'Patent'}
              </span>
              <h3 class="font-semibold mb-1">{pub.title}</h3>
              <p class="text-sm text-[var(--color-text-secondary)]">{pub.authors}</p>
              <p class="text-sm text-[var(--color-text-muted)]">{pub.venue} ({pub.year})</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Additional Experience -->
      <section class="mb-16">
        <h2 class="text-2xl font-bold mb-8 pb-2 border-b border-[var(--color-border)]">
          Additional Experience
        </h2>
        <div class="space-y-3">
          {additionalExperience.map((exp) => (
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-1 py-2 border-b border-[var(--color-border)] last:border-0">
              <div>
                <span class="font-semibold">{exp.role}</span>
                <span class="text-[var(--color-text-secondary)]"> - {exp.course}</span>
                {exp.link && (
                  <a href={exp.link} target="_blank" rel="noopener" class="ml-2 text-[var(--color-accent)] text-sm hover:underline">
                    [Video]
                  </a>
                )}
              </div>
              <span class="text-sm text-[var(--color-text-muted)]">{exp.period}</span>
            </div>
          ))}
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
