---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagBadge from '../../components/blog/TagBadge.astro';
import BlogSidebar from '../../components/blog/BlogSidebar.astro';
import Breadcrumb from '../../components/common/Breadcrumb.astro';
import { toSlug, getTagUrl } from '../../lib/utils';
import { getPublishedPosts, getAllSeries, getAllTags, type BlogPost } from '../../lib/posts';

export async function getStaticPaths() {
  const allPosts = await getPublishedPosts();
  const allSeries = getAllSeries(allPosts);

  return allSeries.map((series) => ({
    params: { series: toSlug(series) },
    props: {
      seriesName: series,
      allPosts,
      posts: allPosts
        .filter((p) => p.data.series === series)
        .sort((a, b) => (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0)),
    },
  }));
}

interface Props {
  seriesName: string;
  posts: BlogPost[];
  allPosts: BlogPost[];
}

const { seriesName, posts, allPosts } = Astro.props;
const allTags = getAllTags(posts);

const chapterMap = new Map<string, BlogPost[]>();
for (const post of posts) {
  const parts = post.id.split('/');
  // category/series-slug/[chapter/]section — depth ≥ 4 means a chapter level exists
  const chapter = parts.length >= 4 ? parts[2] : '_flat';
  if (!chapterMap.has(chapter)) chapterMap.set(chapter, []);
  chapterMap.get(chapter)!.push(post);
}
const chapters = [...chapterMap.entries()]
  .map(([key, ps]) => ({ key, posts: ps, label: formatChapter(key) }))
  .sort((a, b) => (a.posts[0]?.data.seriesOrder ?? 0) - (b.posts[0]?.data.seriesOrder ?? 0));
const hasChapters = chapters.some((c) => c.label !== '');

function formatChapter(key: string): string {
  if (key === '_flat') return '';
  const m = key.match(/^ch(\d+)(?:-(.+))?$/);
  if (!m) return key;
  const num = String(parseInt(m[1], 10)).padStart(2, '0');
  if (!m[2]) return `Chapter ${num}`;
  const title = m[2]
    .split('-')
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
  return `Chapter ${num} · ${title}`;
}
---

<BaseLayout title={`${seriesName} - Series`} description={`${seriesName} 시리즈의 모든 글`}>
  <section class="py-16">
    <div class="container">
      <div class="lg:flex lg:gap-12">
        <!-- Main Content -->
        <div class="flex-1 min-w-0">
          <Breadcrumb items={[{ label: 'Blog', href: '/blog' }, { label: seriesName }]} />

          <div class="mb-8">
            <div class="text-sm text-[var(--color-accent)] font-medium mb-2">
              Series · {posts.length} posts
            </div>
            <h1 class="text-4xl font-bold mb-4">{seriesName}</h1>
            <div class="flex flex-wrap gap-2">
              {allTags.map((tag) => (
                <a href={getTagUrl(tag)}>
                  <TagBadge tag={tag} />
                </a>
              ))}
            </div>
          </div>

          <div class="space-y-6">
            {chapters.map((chapter) => {
              const items = (
                <div class:list={['space-y-2.5 mt-3', hasChapters && chapter.label ? 'sm:pl-4 border-l border-[var(--color-border)]/60 ml-1.5' : '']}>
                  {chapter.posts.map((post, index) => (
                    <a
                      href={`/blog/${post.id}`}
                      class="series-item block p-5 bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-xl hover:border-[var(--color-accent)] hover:shadow-md transition-all duration-200 group"
                    >
                      <div class="flex items-start gap-4">
                        <div class="flex-shrink-0 w-9 h-9 flex items-center justify-center bg-[var(--color-accent)]/15 text-[var(--color-accent)] font-semibold rounded-lg text-sm group-hover:bg-[var(--color-accent)] group-hover:text-white transition-colors">
                          {hasChapters ? index + 1 : post.data.seriesOrder || index + 1}
                        </div>
                        <div class="flex-1 min-w-0">
                          <h3
                            class="text-base sm:text-lg font-semibold group-hover:text-[var(--color-accent)] transition-colors leading-snug"
                            transition:name={`title-${post.id}`}
                          >
                            {post.data.title}
                          </h3>
                          {post.data.description && (
                            <p class="text-sm text-[var(--color-text-secondary)] mt-1.5 line-clamp-2 leading-relaxed">
                              {post.data.description}
                            </p>
                          )}
                        </div>
                      </div>
                    </a>
                  ))}
                </div>
              );

              if (!hasChapters || !chapter.label) {
                return <div>{items}</div>;
              }

              return (
                <details open class="series-chapter group">
                  <summary class="flex items-center gap-2.5 cursor-pointer select-none list-none py-1.5 px-1 -mx-1 rounded-md hover:bg-[var(--color-bg-secondary)]/50 transition-colors">
                    <svg
                      class="w-3 h-3 text-[var(--color-text-muted)] transition-transform duration-200 ease-out group-open:rotate-90 shrink-0"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                    </svg>
                    <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] group-hover:text-[var(--color-text-secondary)] transition-colors">
                      {chapter.label}
                    </span>
                    <span class="inline-flex items-center justify-center min-w-[1.5rem] h-5 px-1.5 text-[10px] font-medium bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)] rounded-full">
                      {chapter.posts.length}
                    </span>
                    <span class="flex-1 h-px bg-[var(--color-border)]" aria-hidden="true"></span>
                  </summary>
                  {items}
                </details>
              );
            })}
          </div>
        </div>

        <!-- Sidebar -->
        <BlogSidebar posts={allPosts} activeFilter={{ type: 'series', value: seriesName }} />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hide the native marker (Safari renders ▸ by default even with list-none) */
  .series-chapter > summary::-webkit-details-marker { display: none; }
  .series-chapter > summary::marker { content: ''; }

  /* Subtle slide on item hover — affords "drilling in" */
  .series-item {
    transform: translateX(0);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .series-item:hover {
    transform: translateX(2px);
  }

  /* Fade-in items when chapter opens (no JS needed; details exposes :state) */
  @media (prefers-reduced-motion: no-preference) {
    .series-chapter[open] > div,
    .series-chapter[open] > * + div {
      animation: chapter-reveal 0.2s ease-out;
    }
  }
  @keyframes chapter-reveal {
    from { opacity: 0; transform: translateY(-2px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
