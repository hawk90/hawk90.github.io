---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagBadge from '../../components/blog/TagBadge.astro';
import TableOfContents from '../../components/blog/TableOfContents.astro';
import SeriesNav from '../../components/blog/SeriesNav.astro';
import SeriesSidebar from '../../components/blog/SeriesSidebar.astro';
import Giscus from '../../components/blog/Giscus.astro';
import RelatedPosts from '../../components/blog/RelatedPosts.astro';
import ShareButtons from '../../components/blog/ShareButtons.astro';
import { formatDate, getTagUrl } from '../../lib/utils';
import { getReadingTime, getRelatedPosts } from '../../lib/posts';
import { SHARE_CONFIG, RELATED_POSTS_CONFIG, SITE_CONFIG } from '../../consts/config';
import { t } from '../../consts/ui-strings';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };

const { post } = Astro.props;
const { Content, headings } = await post.render();

let seriesPosts: CollectionEntry<'blog'>[] = [];
if (post.data.series) {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  seriesPosts = allPosts
    .filter((p) => p.data.series === post.data.series)
    .sort((a, b) => (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0));
}

// Reading time
const readingTime = getReadingTime(post.body || '');

// Related posts
let relatedPosts: CollectionEntry<'blog'>[] = [];
if (RELATED_POSTS_CONFIG.enabled) {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  relatedPosts = getRelatedPosts(post, allPosts, RELATED_POSTS_CONFIG.maxPosts);
}

const formattedDate = formatDate(post.data.date);
const postUrl = new URL(`/blog/${post.slug}`, SITE_CONFIG.url).toString();
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={`/og/${post.slug}.png`}
  type="article"
  showProgress={true}
  publishedTime={post.data.date}
  author={post.data.author}
>
  <article class="py-16">
    <div class="container">
      <div class="lg:flex lg:gap-12">
        <!-- Main Content -->
        <div class="flex-1 min-w-0">
          <!-- Header -->
          <header class="container-narrow mb-12">
            {post.data.series && (
              <div class="text-sm text-[var(--color-accent)] font-medium mb-2">
                {post.data.series} · {post.data.seriesOrder}/{seriesPosts.length}
              </div>
            )}
            <h1 class="text-3xl lg:text-4xl font-bold leading-tight mb-4">
              {post.data.title}
            </h1>
            <div class="flex flex-wrap items-center gap-4 text-[var(--color-text-muted)]">
              <time datetime={post.data.date.toISOString()}>
                {formattedDate}
              </time>
              <span>·</span>
              <span>{post.data.author}</span>
              <span>·</span>
              <span>{readingTime}{t('reading_time_min')}</span>
            </div>
            <div class="flex flex-wrap gap-2 mt-4">
              {post.data.tags.map((tag) => (
                <a href={getTagUrl(tag)}>
                  <TagBadge tag={tag} />
                </a>
              ))}
            </div>

            {SHARE_CONFIG.enabled && (
              <ShareButtons title={post.data.title} url={postUrl} />
            )}
          </header>

          <!-- Mobile TOC Toggle -->
          {headings.filter((h) => h.depth >= 2 && h.depth <= 3).length > 0 && (
            <div class="container-narrow mb-6 lg:hidden">
              <button
                type="button"
                id="mobile-toc-toggle"
                class="w-full flex items-center justify-between px-4 py-3 bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-lg text-sm font-medium text-[var(--color-text-secondary)] hover:border-[var(--color-border-hover)] transition-colors"
                aria-expanded="false"
                aria-controls="mobile-toc"
                aria-label={t('toc_open_close')}
              >
                <span>{t('toc')}</span>
                <svg class="w-4 h-4 transition-transform duration-200" data-toc-chevron fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <nav id="mobile-toc" class="hidden mt-2 px-4 py-3 bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-lg" aria-label="Table of contents">
                <ul class="space-y-2 text-sm">
                  {headings.filter((h) => h.depth >= 2 && h.depth <= 3).map((heading) => (
                    <li style={`padding-left: ${(heading.depth - 2) * 0.75}rem`}>
                      <a
                        href={`#${heading.slug}`}
                        class="block py-1 text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors"
                        data-mobile-toc-link
                      >
                        {heading.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          )}

          <!-- Content -->
          <div class="container-narrow prose">
            <Content />
          </div>

          <!-- Series Navigation (Bottom) -->
          {seriesPosts.length > 1 && (
            <div class="container-narrow mt-12">
              <SeriesNav posts={seriesPosts} currentSlug={post.slug} showAll />
            </div>
          )}

          <!-- Related Posts -->
          {RELATED_POSTS_CONFIG.enabled && relatedPosts.length > 0 && (
            <div class="container-narrow">
              <RelatedPosts posts={relatedPosts} />
            </div>
          )}

          <!-- Comments -->
          <div class="container-narrow mt-16">
            <Giscus />
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="hidden lg:block w-64 shrink-0">
          <div class="sticky top-24">
            {seriesPosts.length > 1 && (
              <SeriesSidebar
                seriesName={post.data.series!}
                posts={seriesPosts}
                currentSlug={post.slug}
              />
            )}
            <TableOfContents headings={headings} />
          </div>
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  function initMobileToc() {
    const toggle = document.getElementById('mobile-toc-toggle');
    const toc = document.getElementById('mobile-toc');
    const chevron = toggle?.querySelector('[data-toc-chevron]');
    if (!toggle || !toc) return;

    function handleToggle() {
      const isExpanded = toggle!.getAttribute('aria-expanded') === 'true';
      toggle!.setAttribute('aria-expanded', String(!isExpanded));
      toc!.classList.toggle('hidden');
      chevron?.classList.toggle('rotate-180');
    }

    function handleLinkClick() {
      toggle!.setAttribute('aria-expanded', 'false');
      toc!.classList.add('hidden');
      chevron?.classList.remove('rotate-180');
    }

    toggle.addEventListener('click', handleToggle);
    toc.querySelectorAll('[data-mobile-toc-link]').forEach((link) => {
      link.addEventListener('click', handleLinkClick);
    });
  }

  initMobileToc();
  document.addEventListener('astro:page-load', initMobileToc);
</script>
