---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ABOUT_DATA } from '../consts/about';
---

<BaseLayout title={`Who Am I - ${ABOUT_DATA.name}`} description={ABOUT_DATA.title}>
  <section class="py-16 lg:py-24">
    <div class="container">
      <div class="max-w-4xl mx-auto">
      <div class="card card-hero p-8 lg:p-10 mb-16">
        <div class="grid lg:grid-cols-5 gap-8 lg:gap-12 items-center">
          <div class="lg:col-span-2 flex justify-center lg:justify-start">
            <img
              src={ABOUT_DATA.photo}
              alt={ABOUT_DATA.name}
              class="w-48 h-48 lg:w-56 lg:h-56 object-cover rounded-3xl shadow-lg ring-1 ring-[var(--color-border)]"
              width="224"
              height="224"
              loading="eager"
              decoding="async"
            />
          </div>

          <div class="lg:col-span-3">
            <div class="section-eyebrow mb-4">About</div>
            <h1 class="text-3xl lg:text-4xl font-bold mb-4">
              Hi, I'm <span class="text-[var(--color-accent)]">{ABOUT_DATA.name}</span>
            </h1>
            <p class="text-xl text-[var(--color-text-secondary)] leading-relaxed mb-6">
              {ABOUT_DATA.tagline}
            </p>
            <div class="flex flex-wrap gap-2.5">
              {ABOUT_DATA.skills.map((skill) => (
                <span
                  class:list={[
                    'inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-full border transition-transform hover:-translate-y-0.5',
                    `skill-chip skill-${skill.color}`,
                  ]}
                >
                  <span aria-hidden="true">{skill.icon}</span>
                  <span>{skill.label}</span>
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-6">
        {ABOUT_DATA.sections.map((section) => (
          <section class="card card-panel">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-2xl">{section.icon}</span>
              <h2 class="text-xl font-bold">{section.title}</h2>
            </div>
            <p class="text-[var(--color-text-secondary)] leading-relaxed pl-10 max-w-3xl">
              {section.content}
            </p>
          </section>
        ))}

        {ABOUT_DATA.hobbies.length > 0 && (
          <section class="card card-panel">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-2xl">🎯</span>
              <h2 class="text-xl font-bold">Hobbies</h2>
            </div>
            <div class="flex flex-wrap gap-x-6 gap-y-2 pl-10 text-[var(--color-text-secondary)]">
              {ABOUT_DATA.hobbies.map((hobby) => (
                <span class="inline-flex items-center gap-2">
                  <span class="text-xl">{hobby.icon}</span>
                  <span class="text-sm">{hobby.label}</span>
                </span>
              ))}
            </div>
          </section>
        )}
      </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Per-skill accent — each chip in its own hue, all share the same level */
  .skill-chip { transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .skill-chip:hover { box-shadow: 0 4px 10px rgba(0, 0, 0, 0.12); }

  .skill-cyan   { background: rgba(34, 211, 238, 0.12); color: #67e8f9; border-color: rgba(34, 211, 238, 0.32); }
  .skill-amber  { background: rgba(251, 146, 60, 0.12); color: #fdba74; border-color: rgba(251, 146, 60, 0.32); }
  .skill-green  { background: rgba(52, 211, 153, 0.12); color: #6ee7b7; border-color: rgba(52, 211, 153, 0.32); }
  .skill-violet { background: rgba(167, 139, 250, 0.15); color: #c4b5fd; border-color: rgba(167, 139, 250, 0.35); }

  html.light .skill-cyan   { color: #0e7490; border-color: rgba(14, 116, 144, 0.30); }
  html.light .skill-amber  { color: #c2410c; border-color: rgba(194, 65, 12, 0.30); }
  html.light .skill-green  { color: #047857; border-color: rgba(4, 120, 87, 0.30); }
  html.light .skill-violet { color: #6d28d9; border-color: rgba(109, 40, 217, 0.30); }
</style>
