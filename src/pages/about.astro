---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Who Am I - Hawk" description="System & Firmware Developer">
  <section class="py-16 lg:py-24">
    <div class="container">
      <div class="max-w-4xl mx-auto">
      <!-- Hero Section: 2-column layout -->
      <div class="grid lg:grid-cols-5 gap-8 lg:gap-12 items-center mb-16">
        <!-- Image -->
        <div class="lg:col-span-2 flex justify-center lg:justify-start">
          <img
            src="/images/pic.jpg"
            alt="Hawk"
            class="w-48 h-48 lg:w-56 lg:h-56 object-cover rounded-2xl shadow-lg"
          />
        </div>

        <!-- Intro -->
        <div class="lg:col-span-3">
          <h1 class="text-3xl lg:text-4xl font-bold mb-4">
            Hi, I'm <span class="text-[var(--color-accent)]">Hawk</span>
          </h1>
          <p class="text-xl text-[var(--color-text-secondary)] leading-relaxed mb-6">
            System & Firmware Developer with a passion for working close to the hardware.
          </p>
          <div class="flex flex-wrap gap-3">
            <span class="px-3 py-1 text-sm bg-[var(--color-bg-tertiary)] rounded-full">Embedded Systems</span>
            <span class="px-3 py-1 text-sm bg-[var(--color-bg-tertiary)] rounded-full">ARM / RISC-V</span>
            <span class="px-3 py-1 text-sm bg-[var(--color-bg-tertiary)] rounded-full">Jetson Orin</span>
            <span class="px-3 py-1 text-sm bg-[var(--color-bg-tertiary)] rounded-full">Kernel Porting</span>
          </div>
        </div>
      </div>

      <!-- Content Sections -->
      <div class="space-y-8">
        <!-- Area of Expertise -->
        <div>
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">🔧</span>
            <h2 class="text-xl font-bold">Area of Expertise</h2>
          </div>
          <p class="text-[var(--color-text-secondary)] leading-relaxed pl-10">
            I'm a System & Firmware Developer with a passion for working close to the hardware.
            My experience spans embedded systems, low-level debugging, board bring-up,
            bootloader development, and kernel porting across various platforms.
          </p>
        </div>

        <!-- What I'm Working On -->
        <div>
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">🚀</span>
            <h2 class="text-xl font-bold">What I'm Working On</h2>
          </div>
          <p class="text-[var(--color-text-secondary)] leading-relaxed pl-10">
            These days, I primarily work on firmware development for platforms like ARM-based systems,
            RISC-V architectures, and Jetson Orin. My focus lies in performance optimization
            and ensuring system reliability.
          </p>
        </div>

        <!-- Purpose of This Blog -->
        <div>
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">✍️</span>
            <h2 class="text-xl font-bold">Purpose of This Blog</h2>
          </div>
          <p class="text-[var(--color-text-secondary)] leading-relaxed pl-10">
            This blog is a space where I document what I learn through hands-on development.
            I aim to share insights into system and firmware development, practical debugging tips,
            and the joy of digging into registers and low-level code.
          </p>
        </div>

        <!-- To Visitors -->
        <div>
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">🤝</span>
            <h2 class="text-xl font-bold">To Visitors</h2>
          </div>
          <p class="text-[var(--color-text-secondary)] leading-relaxed pl-10">
            If you're interested in system software, currently learning, or working in the same field,
            you're more than welcome here. Feel free to leave comments or feedback—I'd love to connect
            and learn together.
          </p>
        </div>

        <!-- Hobbies -->
        <div>
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">🎯</span>
            <h2 class="text-xl font-bold">Hobbies</h2>
          </div>
          <div class="flex gap-6 pl-10">
            <div class="flex flex-col items-center gap-2 p-4 bg-[var(--color-bg-secondary)] rounded-xl border border-[var(--color-border)]">
              <span class="text-3xl">🎾</span>
              <span class="text-sm text-[var(--color-text-secondary)]">Tennis</span>
            </div>
            <div class="flex flex-col items-center gap-2 p-4 bg-[var(--color-bg-secondary)] rounded-xl border border-[var(--color-border)]">
              <span class="text-3xl">🛹</span>
              <span class="text-sm text-[var(--color-text-secondary)]">Skateboard</span>
            </div>
            <div class="flex flex-col items-center gap-2 p-4 bg-[var(--color-bg-secondary)] rounded-xl border border-[var(--color-border)]">
              <span class="text-3xl">🎻</span>
              <span class="text-sm text-[var(--color-text-secondary)]">Violin</span>
            </div>
          </div>
        </div>
      </div>
      </div>
    </div>
  </section>
</BaseLayout>
