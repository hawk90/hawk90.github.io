---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ABOUT_DATA } from '../consts/about';
import { SITE_CONFIG } from '../consts/config';
---

<BaseLayout title={`Who Am I - ${ABOUT_DATA.name}`} description={ABOUT_DATA.title}>
  <section class="py-16 lg:py-24">
    <div class="container">
      <div class="max-w-4xl mx-auto">
      <!-- Hero Section: 2-column layout -->
      <div class="grid lg:grid-cols-5 gap-8 lg:gap-12 items-center mb-16">
        <!-- Image -->
        <div class="lg:col-span-2 flex justify-center lg:justify-start">
          <img
            src={ABOUT_DATA.photo}
            alt={ABOUT_DATA.name}
            class="w-48 h-48 lg:w-56 lg:h-56 object-cover rounded-2xl shadow-lg"
            width="224"
            height="224"
            loading="eager"
            decoding="async"
          />
        </div>

        <!-- Intro -->
        <div class="lg:col-span-3">
          <h1 class="text-3xl lg:text-4xl font-bold mb-4">
            Hi, I'm <span class="text-[var(--color-accent)]">{ABOUT_DATA.name}</span>
          </h1>
          <p class="text-xl text-[var(--color-text-secondary)] leading-relaxed mb-6">
            {ABOUT_DATA.tagline}
          </p>
          <div class="flex flex-wrap gap-3">
            {ABOUT_DATA.skills.map((skill) => (
              <span class="px-3 py-1 text-sm bg-[var(--color-bg-tertiary)] rounded-full">{skill}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- Content Sections -->
      <div class="space-y-8">
        {ABOUT_DATA.sections.map((section) => (
          <div>
            <div class="flex items-center gap-3 mb-3">
              <span class="text-2xl">{section.icon}</span>
              <h2 class="text-xl font-bold">{section.title}</h2>
            </div>
            <p class="text-[var(--color-text-secondary)] leading-relaxed pl-10">
              {section.content}
            </p>
          </div>
        ))}

        <!-- Hobbies -->
        {ABOUT_DATA.hobbies.length > 0 && (
          <div>
            <div class="flex items-center gap-3 mb-3">
              <span class="text-2xl">🎯</span>
              <h2 class="text-xl font-bold">Hobbies</h2>
            </div>
            <div class="flex flex-wrap gap-x-6 gap-y-2 pl-10 text-[var(--color-text-secondary)]">
              {ABOUT_DATA.hobbies.map((hobby) => (
                <span class="inline-flex items-center gap-2">
                  <span class="text-xl">{hobby.icon}</span>
                  <span class="text-sm">{hobby.label}</span>
                </span>
              ))}
            </div>
          </div>
        )}
      </div>
      </div>
    </div>
  </section>
</BaseLayout>
