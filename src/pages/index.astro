---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/blog/PostCard.astro';
import { BRAND_CONFIG } from '../consts/config';
import { t } from '../consts/ui-strings';
import { getHomepageLatestWriting, getPostMeta } from '../lib/posts';
import { formatDate } from '../lib/utils';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const { featuredLatestPosts, heroPost, secondaryLatestPosts } = getHomepageLatestWriting(allPosts);
const heroPostMeta = heroPost ? getPostMeta(heroPost) : null;
---

<BaseLayout title={`${BRAND_CONFIG.heroTitle} - ${BRAND_CONFIG.tagline}`}>
  <!-- Hero Section -->
  <section class="py-16 lg:py-24 overflow-hidden">
    <div class="container">
      <div class="grid lg:grid-cols-[minmax(0,1.05fr)_minmax(22rem,0.95fr)] gap-12 items-center">
        <!-- Text Content -->
        <div class="order-2 lg:order-1">
          <div class="section-eyebrow mb-4">Systems Notes</div>
          <h1 class="text-4xl lg:text-5xl xl:text-6xl font-bold leading-[1.05] mb-6">
            Hi, I'm <span class="text-[var(--color-accent)]">{BRAND_CONFIG.heroTitle}</span>
          </h1>
          <p class="text-xl lg:text-2xl text-[var(--color-text-secondary)] leading-relaxed mb-8 max-w-2xl">
            {BRAND_CONFIG.heroDescription}
          </p>
          <div class="flex flex-wrap gap-3 text-sm">
            <a href="/blog" class="btn btn-primary rounded-xl px-5 py-3">Read the blog</a>
            <a href="/about" class="btn btn-ghost rounded-xl border border-[var(--color-border)] px-5 py-3">About the author</a>
          </div>
        </div>

        <!-- Hero Illustration -->
        <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
          <img
            src="/images/hero-illustration.svg"
            alt="Code editor illustration with C++ code"
            class="w-full max-w-md lg:max-w-lg xl:max-w-xl hero-float"
            width="512"
            height="512"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <style>
    @keyframes heroFloat {
      0%, 100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-10px);
      }
    }

    .hero-float {
      animation: heroFloat 4s ease-in-out infinite;
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-float {
        animation: none;
      }
    }
  </style>

  <!-- Latest Writing -->
  <section class="surface-section py-16">
    <div class="container">
      <div class="flex items-end justify-between gap-4 mb-8">
        <div>
          <div class="section-eyebrow mb-2">Latest Writing</div>
          <h2 class="text-2xl lg:text-3xl font-bold">Start with the newest post, then branch out</h2>
        </div>
        <a href="/blog" class="text-[var(--color-accent)] hover:underline">
          {t('view_all')}
        </a>
      </div>

      <div class="grid gap-6 xl:grid-cols-[minmax(0,1.35fr)_minmax(22rem,0.95fr)]">
        {heroPost && (
          <article class="card card-hero relative overflow-hidden group min-h-[21rem]">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(167,139,250,0.16),transparent_40%)] pointer-events-none"></div>
            <div class="relative flex h-full flex-col justify-between">
              <div class="flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-accent)] mb-4">
                <span>Latest Post</span>
                {heroPost.data.series && <span class="text-[var(--color-text-muted)]">{heroPost.data.series}</span>}
              </div>
              <a href={`/blog/${heroPost.id}`} class="block">
                <h3 class="text-2xl lg:text-3xl font-bold leading-tight mb-4 group-hover:text-[var(--color-accent)] transition-colors">
                  {heroPost.data.title}
                </h3>
                {heroPost.data.description && (
                  <p class="text-base text-[var(--color-text-secondary)] leading-relaxed mb-6 max-w-2xl">
                    {heroPost.data.description}
                  </p>
                )}
                <div class="mt-8 flex flex-wrap items-center gap-3 text-sm text-[var(--color-text-muted)]">
                  <span>{formatDate(heroPost.data.date, 'short')}</span>
                  <span class="w-1 h-1 rounded-full bg-[var(--color-border-hover)]"></span>
                  <span>{heroPostMeta?.readingTime}{t('reading_time_min')}</span>
                  <span class="w-1 h-1 rounded-full bg-[var(--color-border-hover)]"></span>
                  <span>{heroPost.data.tags.slice(0, 3).join(' · ')}</span>
                </div>
              </a>
            </div>
          </article>
        )}

        <section class="card card-panel h-full">
          <div class="flex items-center justify-between gap-4 mb-4">
            <h3 class="text-lg font-semibold">{t('latest_posts')}</h3>
            <a href="/blog" class="text-sm text-[var(--color-accent)] hover:underline">
              {t('view_all')}
            </a>
          </div>

          <ul class="space-y-3">
            {secondaryLatestPosts.map((post) => {
              const { formattedDate, readingTime } = getPostMeta(post);
              return (
                <li class="border-b border-[var(--color-border-faint)] last:border-b-0 last:pb-0 pb-3">
                  <a href={`/blog/${post.id}`} class="block rounded-xl px-2 py-2 transition-colors hover:bg-[var(--color-bg-tertiary)]">
                    {post.data.series && (
                      <div class="text-[11px] font-medium text-[var(--color-accent)] mb-1 truncate">
                        {post.data.series}
                      </div>
                    )}
                    <div class="font-medium leading-snug text-[var(--color-text-primary)] line-clamp-2">
                      {post.data.title}
                    </div>
                    <div class="mt-2 flex flex-wrap items-center gap-2 text-xs text-[var(--color-text-muted)]">
                      <time datetime={post.data.date.toISOString()}>
                        {formattedDate}
                      </time>
                      <span>·</span>
                      <span>{readingTime}{t('reading_time_min')}</span>
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      </div>
    </div>
  </section>

  <!-- Recent Posts -->
  <section class="surface-section py-16">
    <div class="container">
      <div class="flex items-center justify-between mb-8">
        <div>
          <div class="section-eyebrow mb-2">Archive Pulse</div>
          <h2 class="text-2xl font-bold">{t('recent_posts')}</h2>
        </div>
        <a href="/blog" class="text-[var(--color-accent)] hover:underline">
          {t('view_all')}
        </a>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {featuredLatestPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
