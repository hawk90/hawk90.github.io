---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/blog/PostCard.astro';
import { BRAND_CONFIG } from '../consts/config';
import { t } from '../consts/ui-strings';
import { getHomepageLatestWriting } from '../lib/posts';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const { featuredLatestPosts } = getHomepageLatestWriting(allPosts);
---

<BaseLayout title={`${BRAND_CONFIG.heroTitle} - ${BRAND_CONFIG.tagline}`}>
  <!-- Hero Section -->
  <section class="py-16 lg:py-24 overflow-hidden">
    <div class="container">
      <div class="grid lg:grid-cols-[minmax(0,1.05fr)_minmax(22rem,0.95fr)] gap-12 items-center">
        <!-- Text Content -->
        <div class="order-2 lg:order-1">
          <div class="section-eyebrow mb-4">Systems Notes</div>
          <h1 class="text-4xl lg:text-5xl xl:text-6xl font-bold leading-[1.05] mb-6">
            Hi, I'm <span class="text-[var(--color-accent)]">{BRAND_CONFIG.heroTitle}</span>
          </h1>
          <p class="text-xl lg:text-2xl text-[var(--color-text-secondary)] leading-relaxed mb-8 max-w-2xl">
            {BRAND_CONFIG.heroDescription}
          </p>
          <div class="flex flex-wrap gap-3 text-sm">
            <a href="/blog" class="btn btn-primary rounded-xl px-5 py-3">Read the blog</a>
            <a href="/about" class="btn btn-ghost rounded-xl border border-[var(--color-border)] px-5 py-3">About the author</a>
          </div>
        </div>

        <!-- Hero Illustration -->
        <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
          <img
            src="/images/hero-illustration.svg"
            alt="Code editor illustration with C++ code"
            class="w-full max-w-md lg:max-w-lg xl:max-w-xl hero-float"
            width="512"
            height="512"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <style>
    @keyframes heroFloat {
      0%, 100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-10px);
      }
    }

    .hero-float {
      animation: heroFloat 4s ease-in-out infinite;
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-float {
        animation: none;
      }
    }
  </style>

  <!-- Recent Posts -->
  <section class="surface-section py-16">
    <div class="container">
      <div class="flex items-center justify-between mb-8">
        <div>
          <div class="section-eyebrow mb-2">Archive Pulse</div>
          <h2 class="text-2xl font-bold">{t('recent_posts')}</h2>
        </div>
        <a href="/blog" class="text-[var(--color-accent)] hover:underline">
          {t('view_all')}
        </a>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {featuredLatestPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
