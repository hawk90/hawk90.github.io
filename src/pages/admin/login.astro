---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_CONFIG, ADMIN_CONFIG } from '../../consts/config';

const authMode = ADMIN_CONFIG.enabled ? (ADMIN_CONFIG.authMode ?? 'both') : 'both';
const showPat = authMode === 'pat' || authMode === 'both';
const showOAuth = authMode === 'oauth' || authMode === 'both';
---

<BaseLayout
  title={`Admin Login - ${SITE_CONFIG.title}`}
  description="Admin login"
  noIndex={true}
>
  <section class="py-16 min-h-[70vh] flex items-center">
    <div class="container max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold mb-2">Admin Login</h1>
        <p class="text-[var(--color-text-muted)]">Choose your authentication method</p>
      </div>

      <!-- Login Form -->
      <div id="login-form" class="space-y-4">
        <!-- OAuth Button -->
        {showOAuth && (
          <div class="bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-xl p-6">
            <a
              id="oauth-btn"
              href="/api/auth/github"
              class="w-full flex items-center justify-center gap-3 px-6 py-3 bg-[#24292f] hover:bg-[#32383f] text-white font-medium rounded-lg transition-colors"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              Login with GitHub
            </a>
            <p class="text-xs text-center text-[var(--color-text-muted)] mt-3">
              Requires Vercel/Netlify deployment
            </p>
          </div>
        )}

        {showOAuth && showPat && (
          <div class="relative">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-[var(--color-border)]"></div>
            </div>
            <div class="relative flex justify-center text-sm">
              <span class="px-2 bg-[var(--color-bg-primary)] text-[var(--color-text-muted)]">or</span>
            </div>
          </div>
        )}

        <!-- PAT Form -->
        {showPat && (
          <div class="bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-xl p-6">
            <h3 class="font-medium mb-4">Personal Access Token</h3>
            <div class="mb-4">
              <label for="token-input" class="block text-sm font-medium mb-2">
                Token
              </label>
              <input
                type="password"
                id="token-input"
                placeholder="ghp_xxxxxxxxxxxx"
                class="w-full px-4 py-3 bg-[var(--color-bg-primary)] border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-accent)] font-mono text-sm"
              />
              <p class="text-xs text-[var(--color-text-muted)] mt-2">
                Token needs <code class="bg-[var(--color-bg-primary)] px-1 rounded">repo</code> scope
              </p>
            </div>

            <button
              id="login-btn"
              class="w-full flex items-center justify-center gap-3 px-6 py-3 bg-[var(--color-accent)] hover:opacity-90 text-white font-medium rounded-lg transition-opacity"
            >
              Login with Token
            </button>

            <div class="mt-4 pt-4 border-t border-[var(--color-border)]">
              <a
                href="https://github.com/settings/tokens/new?description=Blog%20Admin&scopes=repo"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-2 w-full px-4 py-2 border border-[var(--color-border)] rounded-lg hover:border-[var(--color-border-hover)] transition-colors text-sm"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                Generate Token on GitHub
              </a>
            </div>
          </div>
        )}
      </div>

      <!-- Loading State -->
      <div id="login-loading" class="hidden bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-xl p-8 text-center">
        <div class="inline-block w-8 h-8 border-4 border-[var(--color-border)] border-t-[var(--color-accent)] rounded-full animate-spin"></div>
        <p class="mt-4 text-[var(--color-text-muted)]">Verifying...</p>
      </div>

      <!-- Error State -->
      <div id="login-error" class="hidden bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl p-8 text-center">
        <div class="text-4xl mb-4">⚠️</div>
        <h3 class="font-bold text-red-600 dark:text-red-400 mb-2">Authentication Failed</h3>
        <p id="error-message" class="text-sm text-red-500 dark:text-red-300 mb-4">
          Invalid token or unauthorized user.
        </p>
        <button
          id="retry-btn"
          class="px-4 py-2 bg-[var(--color-accent)] text-white rounded-lg hover:opacity-90 transition-opacity"
        >
          Try Again
        </button>
      </div>

      <!-- Success State -->
      <div id="login-success" class="hidden bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl p-8 text-center">
        <div class="text-4xl mb-4">✅</div>
        <h3 class="font-bold text-green-600 dark:text-green-400 mb-2">Authenticated!</h3>
        <p class="text-sm text-green-500 dark:text-green-300">
          Redirecting to dashboard...
        </p>
      </div>

      <p class="text-center text-sm text-[var(--color-text-muted)] mt-6">
        <a href="/" class="hover:underline">&larr; Back to site</a>
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  import { onPageLoad } from '../../lib/lifecycle';
  import {
    fetchUser,
    saveAuth,
    checkAuth,
    isAllowedUser,
    handleOAuthCallback,
  } from '../../lib/admin/auth';
  import { ADMIN_CONFIG } from '../../consts/config';

  onPageLoad(async () => {
    // Check for OAuth callback (token in hash)
    const oauthResult = handleOAuthCallback();
    if (oauthResult.success) {
      // Successfully authenticated via OAuth - redirect to admin
      window.location.href = '/admin';
      return;
    }

    // Check for OAuth error in query params
    const urlParams = new URLSearchParams(window.location.search);
    const oauthError = urlParams.get('error');

    // Check if already authenticated (with token verification)
    const authState = await checkAuth();
    if (
      authState.isAuthenticated &&
      authState.user &&
      ADMIN_CONFIG.enabled &&
      isAllowedUser(authState.user, ADMIN_CONFIG.allowedUsers)
    ) {
      window.location.href = '/admin';
      return;
    }

    const formEl = document.getElementById('login-form');
    const loadingEl = document.getElementById('login-loading');
    const errorEl = document.getElementById('login-error');
    const successEl = document.getElementById('login-success');
    const tokenInput = document.getElementById('token-input') as HTMLInputElement | null;
    const loginBtn = document.getElementById('login-btn');
    const retryBtn = document.getElementById('retry-btn');
    const errorMessageEl = document.getElementById('error-message');

    function showState(state: 'form' | 'loading' | 'error' | 'success') {
      formEl?.classList.toggle('hidden', state !== 'form');
      loadingEl?.classList.toggle('hidden', state !== 'loading');
      errorEl?.classList.toggle('hidden', state !== 'error');
      successEl?.classList.toggle('hidden', state !== 'success');
    }

    function showError(message: string) {
      if (errorMessageEl) errorMessageEl.textContent = message;
      showState('error');
    }

    // Show OAuth error if present
    if (oauthError) {
      showError(decodeURIComponent(oauthError));
      // Clear the error from URL
      window.history.replaceState(null, '', window.location.pathname);
    }

    async function handlePATLogin() {
      const token = tokenInput?.value.trim();

      if (!token) {
        showError('Please enter a token.');
        return;
      }

      if (!ADMIN_CONFIG.enabled) {
        showError('Admin panel is not enabled.');
        return;
      }

      showState('loading');

      try {
        // Verify token by fetching user
        const user = await fetchUser(token);

        // Check if user is allowed
        if (!isAllowedUser(user, ADMIN_CONFIG.allowedUsers)) {
          showError(`User @${user.login} is not authorized.`);
          return;
        }

        // Save auth and redirect
        saveAuth(token, user);
        showState('success');
        setTimeout(() => {
          window.location.href = '/admin';
        }, 1000);
      } catch (error) {
        console.error('Login failed:', error);
        showError('Invalid token or network error.');
      }
    }

    function handleRetry() {
      if (tokenInput) tokenInput.value = '';
      showState('form');
      tokenInput?.focus();
    }

    // Handle Enter key in token input
    tokenInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        handlePATLogin();
      }
    });

    loginBtn?.addEventListener('click', handlePATLogin);
    retryBtn?.addEventListener('click', handleRetry);

    return () => {
      loginBtn?.removeEventListener('click', handlePATLogin);
      retryBtn?.removeEventListener('click', handleRetry);
    };
  });
</script>
