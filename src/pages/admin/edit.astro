---
/**
 * Edit Post Page
 *
 * Uses query parameter for path: /admin/edit?path=src/content/blog/programming/post-name.md
 * This allows static site generation while supporting dynamic content.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdminGuard from '../../components/admin/AdminGuard.astro';
import { SITE_CONFIG } from '../../consts/config';
---

<BaseLayout
  title={`Edit Post - ${SITE_CONFIG.title}`}
  description="Edit post"
  noIndex={true}
>
  <AdminGuard>
    <section class="py-8">
      <div class="container max-w-4xl">
        <!-- Header -->
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-4">
            <a
              href="/admin"
              class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors"
            >
              ← Back
            </a>
            <h1 class="text-xl font-bold">Edit Post</h1>
            <span id="post-path" class="text-sm text-[var(--color-text-muted)] font-mono"></span>
          </div>
          <div class="flex items-center gap-2">
            <span id="save-status" class="text-sm text-[var(--color-text-muted)]"></span>
            <button
              id="save-btn"
              class="px-4 py-2 bg-[var(--color-accent)] text-white rounded-lg hover:opacity-90 transition-opacity"
            >
              Save Changes
            </button>
            <button
              id="toggle-draft-btn"
              class="px-4 py-2 bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-lg hover:border-[var(--color-border-hover)] transition-colors"
            >
              Publish
            </button>
          </div>
        </div>

        <!-- No Slug State -->
        <div id="no-slug" class="hidden py-16 text-center">
          <div class="text-4xl mb-4">📝</div>
          <h2 class="text-xl font-bold mb-2">No post selected</h2>
          <p class="text-[var(--color-text-muted)] mb-4">Please select a post from the dashboard.</p>
          <a href="/admin" class="text-[var(--color-accent)] hover:underline">Return to Dashboard</a>
        </div>

        <!-- Loading State -->
        <div id="editor-loading" class="py-16 text-center">
          <div class="inline-block w-8 h-8 border-4 border-[var(--color-border)] border-t-[var(--color-accent)] rounded-full animate-spin"></div>
          <p class="mt-4 text-[var(--color-text-muted)]">Loading post...</p>
        </div>

        <!-- Error State -->
        <div id="editor-error" class="hidden py-16 text-center">
          <div class="text-4xl mb-4">❌</div>
          <h2 class="text-xl font-bold mb-2">Failed to load post</h2>
          <p id="error-message" class="text-[var(--color-text-muted)] mb-4">An error occurred.</p>
          <a href="/admin" class="text-[var(--color-accent)] hover:underline">Return to Dashboard</a>
        </div>

        <!-- Editor (hidden until loaded) -->
        <div id="editor-wrapper" class="hidden">
          <!-- Frontmatter Fields -->
          <div class="bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-xl p-6 mb-6">
            <div class="grid gap-4">
              <div>
                <label for="post-title" class="block text-sm font-medium mb-1">Title</label>
                <input
                  type="text"
                  id="post-title"
                  placeholder="Enter post title..."
                  class="w-full px-4 py-2 bg-[var(--color-bg-primary)] border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-accent)] text-lg"
                />
              </div>
              <div>
                <label for="post-description" class="block text-sm font-medium mb-1">Description</label>
                <input
                  type="text"
                  id="post-description"
                  placeholder="A brief description..."
                  class="w-full px-4 py-2 bg-[var(--color-bg-primary)] border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-accent)]"
                />
              </div>
              <div>
                <label for="post-tags" class="block text-sm font-medium mb-1">Tags (comma-separated)</label>
                <input
                  type="text"
                  id="post-tags"
                  placeholder="tag1, tag2, tag3"
                  class="w-full px-4 py-2 bg-[var(--color-bg-primary)] border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-accent)]"
                />
              </div>
              <div class="flex items-center gap-4 text-sm">
                <label class="flex items-center gap-2">
                  <input type="checkbox" id="post-draft" class="w-4 h-4 accent-[var(--color-accent)]" />
                  <span>Draft</span>
                </label>
                <span class="text-[var(--color-text-muted)]">|</span>
                <span id="post-date" class="text-[var(--color-text-muted)]"></span>
              </div>
            </div>
          </div>

          <!-- Editor -->
          <div class="bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-xl overflow-hidden">
            <div class="flex items-center justify-between px-4 py-2 border-b border-[var(--color-border)]">
              <span class="text-sm font-medium">Content</span>
            </div>

            <div class="p-4">
              <textarea
                id="content-textarea"
                class="w-full min-h-[500px] p-4 bg-[var(--color-bg-primary)] border border-[var(--color-border)] rounded-lg font-mono text-sm resize-y focus:outline-none focus:border-[var(--color-accent)]"
                placeholder="Write your content in Markdown..."
              ></textarea>
            </div>
          </div>

          <!-- Danger Zone -->
          <div class="mt-8 p-6 border border-red-200 dark:border-red-800 rounded-xl">
            <h3 class="text-red-600 dark:text-red-400 font-semibold mb-2">Danger Zone</h3>
            <p class="text-sm text-[var(--color-text-muted)] mb-4">
              Deleting a post is permanent and cannot be undone.
            </p>
            <button
              id="delete-btn"
              class="px-4 py-2 text-red-600 dark:text-red-400 border border-red-200 dark:border-red-800 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"
            >
              Delete Post
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Toast -->
    <div id="editor-toast" class="fixed bottom-6 right-6 z-50 opacity-0 pointer-events-none transition-opacity duration-300">
      <div id="toast-content" class="px-4 py-2 bg-[var(--color-accent)] text-white text-sm font-medium rounded-lg shadow-lg">
        Saved!
      </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="delete-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
      <div class="bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-xl p-6 max-w-md mx-4">
        <h3 class="text-lg font-bold mb-2">Delete Post?</h3>
        <p class="text-[var(--color-text-muted)] mb-4">
          This will permanently delete the post. This action cannot be undone.
        </p>
        <div class="flex justify-end gap-2">
          <button
            id="cancel-delete"
            class="px-4 py-2 text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)]"
          >
            Cancel
          </button>
          <button
            id="confirm-delete"
            class="px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600"
          >
            Delete
          </button>
        </div>
      </div>
    </div>
  </AdminGuard>
</BaseLayout>

<script>
  import { onPageLoad } from '../../lib/lifecycle';
  import { getAuthState } from '../../lib/admin/auth';
  import {
    fetchFileWithSha,
    updateFile,
    deleteFile,
    parseRepo,
    splitFrontmatter,
    serializeFrontmatter,
  } from '../../lib/admin/github-api';
  import { ADMIN_CONFIG } from '../../consts/config';

  onPageLoad(async () => {
    // Get post identifier from URL query parameter
    const urlParams = new URLSearchParams(window.location.search);
    const pathParam = urlParams.get('path');
    const slug = urlParams.get('slug');

    // Elements
    const noSlugEl = document.getElementById('no-slug');
    const loadingEl = document.getElementById('editor-loading');
    const errorEl = document.getElementById('editor-error');
    const errorMsgEl = document.getElementById('error-message');
    const wrapperEl = document.getElementById('editor-wrapper');

    const titleInput = document.getElementById('post-title') as HTMLInputElement;
    const descInput = document.getElementById('post-description') as HTMLInputElement;
    const tagsInput = document.getElementById('post-tags') as HTMLInputElement;
    const draftCheckbox = document.getElementById('post-draft') as HTMLInputElement;
    const dateEl = document.getElementById('post-date');
    const pathEl = document.getElementById('post-path');
    const contentTextarea = document.getElementById('content-textarea') as HTMLTextAreaElement;

    const saveBtn = document.getElementById('save-btn');
    const toggleDraftBtn = document.getElementById('toggle-draft-btn');
    const deleteBtn = document.getElementById('delete-btn');
    const saveStatus = document.getElementById('save-status');

    const deleteModal = document.getElementById('delete-modal');
    const cancelDeleteBtn = document.getElementById('cancel-delete');
    const confirmDeleteBtn = document.getElementById('confirm-delete');

    const toastEl = document.getElementById('editor-toast');
    const toastContent = document.getElementById('toast-content');

    let currentSha = '';
    let currentPath = '';
    let isDraft = true;
    let publishedDate = '';

    // Check if a post identifier is provided
    if (!pathParam && !slug) {
      loadingEl?.classList.add('hidden');
      noSlugEl?.classList.remove('hidden');
      return;
    }

    function showToast(message: string, type: 'success' | 'error' = 'success') {
      if (!toastEl || !toastContent) return;

      toastContent.textContent = message;
      toastContent.className = `px-4 py-2 text-white text-sm font-medium rounded-lg shadow-lg ${
        type === 'error' ? 'bg-red-500' : 'bg-[var(--color-accent)]'
      }`;

      toastEl.classList.remove('opacity-0', 'pointer-events-none');
      toastEl.classList.add('opacity-100');

      setTimeout(() => {
        toastEl.classList.remove('opacity-100');
        toastEl.classList.add('opacity-0', 'pointer-events-none');
      }, 3000);
    }

    function showError(message: string) {
      loadingEl?.classList.add('hidden');
      wrapperEl?.classList.add('hidden');
      noSlugEl?.classList.add('hidden');
      errorEl?.classList.remove('hidden');
      if (errorMsgEl) errorMsgEl.textContent = message;
    }

    // Listen for auth event
    async function handleAuthenticated() {
      const authState = getAuthState();
      if (!authState.accessToken || !ADMIN_CONFIG.enabled) {
        showError('Not authenticated');
        return;
      }

      try {
        const repoString = ADMIN_CONFIG.contentRepo || '';
        const { owner, repo } = parseRepo(repoString);
        const contentPath = ADMIN_CONFIG.contentPath || 'src/content/blog';
        const filePath = await resolvePostPath(authState.accessToken, owner, repo, contentPath);

        currentPath = filePath;
        if (pathEl) pathEl.textContent = filePath;

        const { content, sha } = await fetchFileWithSha(
          authState.accessToken,
          owner,
          repo,
          filePath
        );

        currentSha = sha;

        const { frontmatter, body } = splitFrontmatter(content);

        // Populate fields
        if (titleInput) titleInput.value = (frontmatter.title as string) || '';
        if (descInput) descInput.value = (frontmatter.description as string) || '';
        if (tagsInput) {
          const tags = frontmatter.tags as string[] | undefined;
          tagsInput.value = Array.isArray(tags) ? tags.join(', ') : '';
        }
        if (draftCheckbox) {
          isDraft = frontmatter.draft === true;
          draftCheckbox.checked = isDraft;
        }
        if (dateEl && frontmatter.date) {
          publishedDate = String(frontmatter.date);
          dateEl.textContent = `Date: ${frontmatter.date}`;
        }
        if (contentTextarea) contentTextarea.value = body;

        // Update toggle button text
        if (toggleDraftBtn) {
          toggleDraftBtn.textContent = isDraft ? 'Publish' : 'Unpublish';
        }

        // Show editor
        loadingEl?.classList.add('hidden');
        noSlugEl?.classList.add('hidden');
        wrapperEl?.classList.remove('hidden');
      } catch (error) {
        console.error('Failed to load post:', error);
        showError(error instanceof Error ? error.message : 'Failed to load post');
      }
    }

    async function resolvePostPath(
      accessToken: string,
      owner: string,
      repo: string,
      contentPath: string
    ): Promise<string> {
      if (pathParam) {
        return pathParam;
      }

      const mdPath = `${contentPath}/${slug}.md`;
      try {
        await fetchFileWithSha(accessToken, owner, repo, mdPath);
        return mdPath;
      } catch {
        return `${contentPath}/${slug}.mdx`;
      }
    }

    window.addEventListener('admin:authenticated', handleAuthenticated);

    // Save changes
    async function saveChanges() {
      const authState = getAuthState();
      if (!authState.accessToken || !ADMIN_CONFIG.enabled) return;

      if (saveStatus) saveStatus.textContent = 'Saving...';

      try {
        const repoString = ADMIN_CONFIG.contentRepo || '';
        const { owner, repo } = parseRepo(repoString);
        const branch = ADMIN_CONFIG.branch || 'main';

        // Build new content
        const tags = tagsInput?.value
          ? tagsInput.value.split(',').map((t) => t.trim()).filter(Boolean)
          : [];

        const frontmatter: Record<string, unknown> = {
          title: titleInput?.value || 'Untitled',
          date: publishedDate || new Date().toISOString().split('T')[0],
          draft: draftCheckbox?.checked ?? true,
        };

        if (descInput?.value) frontmatter.description = descInput.value;
        if (tags.length > 0) frontmatter.tags = tags;

        const body = contentTextarea?.value || '';
        const content = buildMarkdown(frontmatter, body);

        const result = await updateFile(
          authState.accessToken,
          owner,
          repo,
          currentPath,
          content,
          currentSha,
          `Update: ${postName(currentPath)}`,
          branch
        );

        currentSha = result.content.sha;
        showToast('Saved!');
        if (saveStatus) saveStatus.textContent = '';
      } catch (error) {
        console.error('Save failed:', error);
        showToast(error instanceof Error ? error.message : 'Failed to save', 'error');
        if (saveStatus) saveStatus.textContent = '';
      }
    }

    function buildMarkdown(frontmatter: Record<string, unknown>, body: string): string {
      return `${serializeFrontmatter(frontmatter)}\n\n${body}`;
    }

    // Pull a human-readable name out of a repo path. Used in commit
    // messages — `slug` from the query string is often null when we
    // navigated by `?path=...`, so deriving from the path is more reliable.
    function postName(p: string): string {
      return p.split('/').pop()?.replace(/\.(md|mdx)$/, '') ?? p;
    }

    // Toggle draft status
    async function toggleDraft() {
      if (draftCheckbox) {
        draftCheckbox.checked = !draftCheckbox.checked;
        isDraft = draftCheckbox.checked;
        if (toggleDraftBtn) {
          toggleDraftBtn.textContent = isDraft ? 'Publish' : 'Unpublish';
        }
        await saveChanges();
      }
    }

    // Delete post
    async function handleDelete() {
      const authState = getAuthState();
      if (!authState.accessToken || !ADMIN_CONFIG.enabled) return;

      try {
        const repoString = ADMIN_CONFIG.contentRepo || '';
        const { owner, repo } = parseRepo(repoString);
        const branch = ADMIN_CONFIG.branch || 'main';

        await deleteFile(
          authState.accessToken,
          owner,
          repo,
          currentPath,
          currentSha,
          `Delete: ${postName(currentPath)}`,
          branch
        );

        showToast('Deleted!');
        setTimeout(() => {
          window.location.href = '/admin';
        }, 1000);
      } catch (error) {
        console.error('Delete failed:', error);
        showToast(error instanceof Error ? error.message : 'Failed to delete', 'error');
      }
    }

    // Event listeners
    saveBtn?.addEventListener('click', saveChanges);
    toggleDraftBtn?.addEventListener('click', toggleDraft);

    deleteBtn?.addEventListener('click', () => {
      deleteModal?.classList.remove('hidden');
    });

    cancelDeleteBtn?.addEventListener('click', () => {
      deleteModal?.classList.add('hidden');
    });

    confirmDeleteBtn?.addEventListener('click', () => {
      deleteModal?.classList.add('hidden');
      handleDelete();
    });

    // Close modal on backdrop click
    deleteModal?.addEventListener('click', (e) => {
      if (e.target === deleteModal) {
        deleteModal.classList.add('hidden');
      }
    });

    return () => {
      window.removeEventListener('admin:authenticated', handleAuthenticated);
    };
  });
</script>
