---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdminGuard from '../../components/admin/AdminGuard.astro';
import { SITE_CONFIG, ADMIN_CONFIG, FOOTER_LINKS, SOCIAL_CONFIG } from '../../consts/config';
---

<BaseLayout
  title={`Admin Settings - ${SITE_CONFIG.title}`}
  description="Admin settings"
  noIndex={true}
>
  <AdminGuard>
    <section class="py-8">
      <div class="container max-w-3xl">
        <div class="flex items-center gap-4 mb-6">
          <a
            href="/admin"
            class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors"
          >
            ← Back
          </a>
          <h1 class="text-2xl font-bold">Admin Settings</h1>
        </div>

        <div class="space-y-6">
          <div class="bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-xl p-6">
            <h2 class="font-semibold mb-4">Current Configuration</h2>
            <dl class="grid gap-3 text-sm">
              <div class="flex justify-between gap-4">
                <dt class="text-[var(--color-text-muted)]">Enabled</dt>
                <dd>{String(ADMIN_CONFIG.enabled)}</dd>
              </div>
              <div class="flex justify-between gap-4">
                <dt class="text-[var(--color-text-muted)]">Client ID</dt>
                <dd class="font-mono">{ADMIN_CONFIG.enabled ? (ADMIN_CONFIG.clientId || 'Not set') : 'Disabled'}</dd>
              </div>
              <div class="flex justify-between gap-4">
                <dt class="text-[var(--color-text-muted)]">Allowed Users</dt>
                <dd>{ADMIN_CONFIG.enabled ? ADMIN_CONFIG.allowedUsers.join(', ') : 'Disabled'}</dd>
              </div>
              <div class="flex justify-between gap-4">
                <dt class="text-[var(--color-text-muted)]">Content Repo</dt>
                <dd class="font-mono">{ADMIN_CONFIG.enabled ? ADMIN_CONFIG.contentRepo : 'Disabled'}</dd>
              </div>
              <div class="flex justify-between gap-4">
                <dt class="text-[var(--color-text-muted)]">Branch</dt>
                <dd class="font-mono">{ADMIN_CONFIG.enabled ? (ADMIN_CONFIG.branch || 'main') : 'Disabled'}</dd>
              </div>
            </dl>
          </div>

          <!-- Footer Links -->
          <div class="bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-xl p-6">
            <h2 class="font-semibold mb-4">Footer Links</h2>
            <ul class="space-y-2 text-sm">
              {FOOTER_LINKS.map((link) => (
                <li class="flex items-center justify-between gap-4 py-1.5 border-b border-[var(--color-border)] last:border-0">
                  <span>{link.label}</span>
                  <code class="text-xs text-[var(--color-text-muted)]">{link.href}</code>
                </li>
              ))}
            </ul>
          </div>

          <!-- Social Links -->
          <div class="bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-xl p-6">
            <h2 class="font-semibold mb-4">Social Links</h2>
            <ul class="space-y-2 text-sm">
              {SOCIAL_CONFIG.map((link) => (
                <li class="flex items-center justify-between gap-4 py-1.5 border-b border-[var(--color-border)] last:border-0">
                  <span class="flex items-center gap-2">
                    <span class="w-4 h-4 [&>svg]:w-4 [&>svg]:h-4 text-[var(--color-text-muted)]">
                      <Fragment set:html={link.icon} />
                    </span>
                    {link.name}
                  </span>
                  <code class="text-xs text-[var(--color-text-muted)] truncate max-w-[200px]">{link.href}</code>
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-xl p-6">
            <h2 class="font-semibold mb-3">How to Update</h2>
            <p class="text-sm text-[var(--color-text-muted)] mb-3">
              All configuration is defined in <code>src/consts/config.ts</code>.
            </p>
            <ul class="space-y-2 text-sm text-[var(--color-text-muted)]">
              <li><strong>FOOTER_LINKS</strong> - Links shown in the site footer</li>
              <li><strong>SOCIAL_CONFIG</strong> - Social media links with icons</li>
              <li><strong>ADMIN_CONFIG</strong> - Admin panel settings</li>
            </ul>
          </div>
        </div>
      </div>
    </section>
  </AdminGuard>
</BaseLayout>
