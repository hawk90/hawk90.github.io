---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import BlogSidebar from '../../components/blog/BlogSidebar.astro';
import Breadcrumb from '../../components/common/Breadcrumb.astro';
import { getPublishedPosts, getAllTags, filterByTag, type BlogPost } from '../../lib/posts';

export async function getStaticPaths() {
  const allPosts = await getPublishedPosts();
  const allTags = getAllTags(allPosts);

  return allTags.map((tag) => ({
    params: { tag: tag.toLowerCase() },
    props: {
      tag,
      posts: filterByTag(allPosts, tag),
    },
  }));
}

interface Props {
  tag: string;
  posts: BlogPost[];
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag} - Tags`} description={`${tag} 태그가 붙은 글`}>
  <section class="py-16">
    <div class="container">
      <div class="lg:flex lg:gap-12">
        <!-- Main Content -->
        <div class="flex-1 min-w-0">
          <Breadcrumb items={[{ label: 'Blog', href: '/blog' }, { label: `#${tag}` }]} />

          <div class="mb-8">
            <h1 class="text-4xl font-bold mb-4 flex items-center gap-3">
              <span class="text-[var(--color-accent)]">#</span>{tag}
            </h1>
            <p class="text-lg text-[var(--color-text-secondary)]">
              {posts.length}개의 포스트
            </p>
          </div>

          {posts.length > 0 ? (
            <div class="grid gap-6 md:grid-cols-2">
              {posts.map((post) => (
                <PostCard post={post} />
              ))}
            </div>
          ) : (
            <div class="empty-state flex flex-col items-center text-center py-16 px-6 border border-dashed border-[var(--color-border)] rounded-2xl">
              <div class="w-16 h-16 rounded-full bg-[var(--color-bg-tertiary)] flex items-center justify-center mb-5">
                <svg class="w-7 h-7 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M7 7h.01M7 3h5a2 2 0 011.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>
                </svg>
              </div>
              <h2 class="text-lg font-semibold mb-2">아직 글이 없어요</h2>
              <p class="text-sm text-[var(--color-text-secondary)] mb-6 max-w-sm">
                <code class="text-[var(--color-accent)]">#{tag}</code> 태그가 붙은 글이 아직 없습니다. 다른 태그를 둘러보거나 전체 글로 돌아가 보세요.
              </p>
              <div class="flex flex-wrap gap-3 justify-center">
                <a href="/tags" class="btn btn-ghost border border-[var(--color-border)]">모든 태그</a>
                <a href="/blog" class="btn btn-primary">전체 글 보기</a>
              </div>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <BlogSidebar activeFilter={{ type: 'tag', value: tag }} />
      </div>
    </div>
  </section>
</BaseLayout>
